		DisplayName: Музыкальная шкатулка (Мятная луна)
	}

	SapphireRing: {
		DisplayName: Сапфировое кольцо
		Tooltip: Даёт бафф «{$Buffs.LunarEmpowermentBuff.DisplayName}»
	}

	TopazRing: {
		DisplayName: Топазовое кольцо
		Tooltip: Даёт бафф «{$Buffs.BountifulHarvestBuff.DisplayName}»
	}

	AmethystRing: {
		DisplayName: Аметистовое кольцо
		Tooltip: Даёт бафф «{$Buffs.FloralBlessingBuff.DisplayName}»
	}

	EmeraldRing: {
		DisplayName: Изумрудное кольцо
		Tooltip: Даёт бафф «{$Buffs.MintyFreshnessBuff.DisplayName}»
	}

	MoonsRing: {
		DisplayName: Лунное кольцо
		Tooltip: Благословляет вас силой четырёх величественных лун
	}
}

Buffs: {
	BountifulHarvestBuff: {
		DisplayName: Невероятная жатва
		Description:
			'''
			Благословение урожайной луны набивает ваши карманы деньгами
			С врагов выпадает больше монет
			'''
	}

	FloralBlessingBuff: {
		DisplayName: Благословение природы
		Description:
			'''
			Примите дар в виде исцеляющей ауры вишнёвой луны
			Ваши раны заживают быстрее
			'''
	}

	LunarEmpowermentBuff: {
		DisplayName: Лунная сила
		Description: Голубая луна дарует вам частичку своей удачи
	}

	MintyFreshnessBuff: {
		DisplayName: Мятная свежесть
		Description: Искрящийся свет мятной луны усиливает ваши магические способности
	}

	MoonsRingBuff: {
		DisplayName: Небесная гармония
		Description: Увеличивает количество выпадаемых с врагов монет, скорость регенерации здоровья, шанс критического удара и магический урон
	}
}

