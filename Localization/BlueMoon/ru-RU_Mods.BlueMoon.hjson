Items: {
	BlueMedallion: {
		DisplayName: Голубой медальон
		Tooltip:
			'''
			Призывает удачливую голубую луну
			Можно использовать только ночью
			'''
	}

	CherryAmulet: {
		DisplayName: Вишнёвый амулет
		Tooltip:
			'''
			Призывает чарующую вишнёвую луну
			Можно использовать только ночью
			'''
	}

	HarvestLantern: {
		DisplayName: Урожайная лампа
		Tooltip:
			'''
			Призывают праздничную урожайную луну
			Можно использовать только ночью
			'''
	}

	MintRing: {
		DisplayName: Мятное кольцо
		Tooltip:
			'''
			Призывает освежающую мятную луну
			Можно использовать только ночью
			'''
	}

	HarvestMoonMusicBox: {
		Tooltip: ""
