Items: {
	AmalgamAmulet: {
		DisplayName: Слившийся амулет
		Tooltip: Даёт 4 секунды невосприимчивости к ртути
	}

	AquaGlove: {
		DisplayName: Аква-перчатка
		Tooltip:
			'''
			Атаки ближнего боя накладывают дебафф «{$Buffs.FreezingWater.DisplayName}»
			Увеличивает отбрасывание ближнего боя
			Увеличивает урон и скорость атаки ближнего боя на 12%
			Включает автоатаку для оружия ближнего боя
			'''
	}

	AquaStone: {
		DisplayName: Аква-камень
		Tooltip: Атаки ближнего боя накладывают дебафф «{$Buffs.FreezingWater.DisplayName}»
	}

