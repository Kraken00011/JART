	}

	TrailblazerBackpack: {
		DisplayName: Тактический рюкзачок следожёга
		Tooltip: "''Быть следожёгом — значит быть готовым. К счастью, в этом рюкзаке одно лишь топливо.'"
	}

	ShogunWings: {
