	ChromaticTorch: {
		DisplayName: Хроматический факел
		Tooltip: ""
	}

	StickyHand: {
		DisplayName: Мерзкая рука
		Tooltip:
			'''
			Автоматически отцепляется, когда вы достаточно близки к крюку
			Удерживайте клавишу использования крюка, чтобы прикрепиться к блоку
			{$}
			'Уверяю вас - она не порвётся'
			'''
	}

	Trailblazer: {
		DisplayName: Следожёг
		Tooltip:
			'''
			Использует гель в качестве боеприпасов
			Игнорирует 15 ед. защиты
			80% шанс не потратить боеприпасы
			'''
	}

	SlimeCane: {
		DisplayName: Слизневая трость
		Tooltip:
			'''
			Призывает команду из 4 слизней-оруженосцев сражаться за вас
			Повторное использование оружия усиливает слизней, используя 1 слот миньонов
			Слизней можно усилить вплоть до 4 раз
			Окончательно усилив команду слизней, призывает Гузмоэм, стреляющий термоядерными лучами
			'Если б я мог избавиться от всей грязи да сделать мир прекрасным, по моему образу и подобию'
			'''
	}

	FissionFlyer: {
		DisplayName: Расщепляющий резак
		Tooltip:
			'''
			Бросает чакрам, разделяющийся на 3 прыгучих кольца
			При скрытном ударе разделяется на большее количество колец и оставляет огромный клинок
			'''
	}

	ScytheOfTheOldGod: {
		DisplayName: Коса старого бога
		Tooltip:
			'''
			Взмахивает огромной косой, разрезающей врагов тройным комбо
			'Не путать с косой Старого герцога...
			и ни чем больше.'
			'''
	}

	Goomoire: {
		DisplayName: Гузмуар
		Tooltip:
			'''
			Колдует сковывающий вихрь, всасывающий в себя противников
			'Только не яма! Я ТАМ СГОРЮ!'
			'''
	}

	SlimeNinjaStatue: {
		DisplayName: Статуя слизневого ниндзя
		Tooltip:
			'''
			Окружите 4-я статуями слизня, после чего используйте желейный катализатор, чтобы вызвать дождь из слизней
			Значительно ускоряет сбор слизней при активации
			'Собственно, а кто он вообще такой?'
			'''
	}

	GelatinousCatalyst: {
		DisplayName: Желейный катализатор
		Tooltip: Используйте на статуе слизневого ниндзя, находящейся возле 4 статуй слизня, чтобы вызвать дождь из слизней
	}

	PluripotentSpawnEgg: {
		DisplayName: Плюрипотентное яйцо призыва
		Tooltip:
			'''
			Используйте на статуе слизневого ниндзя, находящейся возле 4 статуй слизня, чтобы призвать Гузму без дождя
			Не расходуется
			'''
	}

	PaladinPalanquin: {
		DisplayName: Паланкин паладина
		Tooltip:
			'''
			Призывает ездовой масляной шарик
			'Почувствуйте себя императором!'
			'''
	}

	ChromaticBomb: {
		DisplayName: Хроматическая бомба
		Tooltip: Бросает игнорирующую гравитацию чёрную дыру, уничтожающую блоки
	}

	ChromaticGooztick: {
		DisplayName: Хроматическая светящаяся липучка
		Tooltip: Игнорирует гравитацию и отскакивает от блоков
	}

	DynamoRod: {
		DisplayName: Динамо динамит
		Tooltip: Взрывается в виде огромной, разрушающей блоки чёрной дыры
	}

	BadApple: {
		DisplayName: Плохое яблоко
		Tooltip:
			'''
			'Яблоко, упавшее с древа, что пострадало от очередной вспышки ярости Гузмы.
			По виду фрукт перевоплотился во что-то относительно новое, скорее всего ужасное на вкус.
			Но если на зуб яблочко покажется нормальным — запах вас расстроит...'
			'''
	}

	ThrowingStars: {
		DisplayName: Метательные звёзды
		Tooltip: ""
	}

	CometKunai: {
		DisplayName: Кометный кунай
		Tooltip:
			'''
			Выпускает шквал из кунаев и звёзд, создающих собственные копии при успешном попадании
			При скрытном ударе вызывает звёздный дождь при столкновении с чем-либо
			'Мощь звёзд у меня в руках...'
			'''
	}

	GoopHairDye: {
		DisplayName: Склизкая краска для волос
		Tooltip: ""
	}

	AncientSlimeMonsoonMonolith: {
		DisplayName: Монолит древнего муссонового слизня
		Tooltip: ""
	}

	AntiMassAccumulator: {
		DisplayName: Аккумулятор анти-массы
		Tooltip:
			'''
			Выстреливает шарами сгруппированных протонов и болтами заряженных электронов друг за другом
			Шары протонов заряжают всё, чего касаются и могут наносить урон врагам в определённом радиусе
			Болты электронов наносят дополнительный урон положительно заряженным врагам
			'Не смотрите непосредственно на рабочий конец устройства.'
			'''
	}

	GoozmaBoulderItem: {
		DisplayName: Пёстрый шарик
