		DisplayName: Портрет странного мужчины
		Tooltip: ""
	}

	TendrilCursorAttachment: {
		DisplayName: Курсорный мутаген
		Tooltip:
			'''
			Прикрепляет к вашему курсору мыши свисающие хроматические усики
			Количество усиков зависит от слота, в котором находится аксессуар
