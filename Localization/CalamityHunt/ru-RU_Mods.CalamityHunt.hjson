		DisplayName: Помповый болотовик
		Tooltip: Стреляет относительно безобидным всплеском слизи
	}

	Parasanguine: {
		DisplayName: Парасангвинник
		Tooltip:
			'''
			Пока вы держите ЛКМ или наносите урон врагам, накапливаются излишки крови
			Нажмите ПКМ, когда шкала крови заполнена, чтобы выплеснуть излишки
			Нажмите ЛКМ после выплеска крови, чтобы совершить разрушительный взмах
			'Что получается при кормёжке слизня? Слизень побольше.'
			'''
	}

	Gobflogger: {
		DisplayName: Слизьтатель
		Tooltip:
			'''
			{$CommonItemTooltip.SummonTagDamage}
			{$CommonItemTooltip.Whips}
			Бейте противников, чтобы получить небольшой бонус к скорости атаки кнутом
			'Тише едешь - дальше будешь'
			'''
	}

	CrystalGauntlets: {
		DisplayName: Кристаллические перчатки
		Tooltip:
			'''
			Удерживайте ЛКМ, чтобы собирать энергию, формируя мощный шар из молний
			Полностью сформировав шар, отпустите ЛКМ, чтобы выпустить его на встречу своим противникам
			Нажмите ПКМ, чтобы хлопнуть в ладоши, взрывая все выпущенные шары из молний
			'Безграничная власть!'
			'''
	}

	SplendorJam: {
		DisplayName: Варенье великолепия
		Tooltip:
			'''
			Активирует шкалу стресса
			Стресс накапливается постепенно сам собой, однако возле врагов стресс накапливается быстрее
			Вы излучаете свет, сила которого зависит от показателя стресса
			Каждые 0%, 25%, 50%, 75% и 100% достигнутого стресса вы получаете по одной спецтакле
			При достижении 25% стресса, ваше оружие начнёт вызывать взрывы
			При достижении 75% стресса, ваши взрывы становятся больше и сильнее
			Дважды нажмите ВНИЗ, пока уровень стресса выше 25%, чтобы войти в режим злобы
			Режим злобы значительно увеличивает ваш урон, а также даёт фиксированную прибавку к нему, пробиванию брони и шансу критического удара
			Бонусы и их длительность масштабируются с количеством вашего стресса
			'Близится что-то ужасающее...'
			'''
	}

	TheSlimer: {
		DisplayName: Слизневик
		Tooltip:
			'''
			Стреляет существенной суспензией слипающейся слизи
			Во время стрельбы слизь застревает, образуя пробку
			Нажмите ПКМ, пока орудие забито, чтобы выпустить желчную бомбу
			'Не путать с Багровым слизнем'
			'''
	}

	PureAuricSoul: {
		DisplayName: Ауритовая душа
		Tooltip: Поглотите, чтобы получить силы поверженного врага
	}

	SludgeShaker: {
		DisplayName: Сотрясатель слякоти
		Tooltip:
			'''
			Стреляет существенной суспензией слипающейся слизи
			Во время стрельбы слизь прилипает к строениям
			'Встряхнуть, не размешивать'
			'''
	}

	SupremeRestorationPotion: {
		DisplayName: Омега зелье восстановления
		Tooltip: Снижено время перезарядки зелий
		RestoreLifeText: ""
