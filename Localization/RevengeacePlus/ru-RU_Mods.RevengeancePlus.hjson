Configs: {
	DebugConfig: {
		DisplayName: Конфигурация отладки

		calamityDifficulty: {
			Label: Тестировщик режимов Calamity
			Tooltip:
				'''
				Заставляет игру думать, что включена определённая сложность Calamity
				Не работает, если Calamity включён
				0 - Никакая
				1 - Месть
				2 - Смерть
				3 - Злоба или Босс-раш
				'''
		}

		eternityMode: {
			Label: Тестировщик режима Вечность
			Tooltip:
				'''
				Заставляет игру думать, что включен режим Вечности
				Не работает, если Fargo's Souls включён
				'''
		}

		forceHJAltSprites: {
			Label: Постоянное отображение альтернативных спрайтов Homeward Journey
			Tooltip:
				'''
				У некоторых боссов из Homeward Journey могут быть альтернативные спрайты
				Это конфигурация включает их, чтобы протестировать сломает ли это что-либо
				'''
		}
	}

	SupportedModsConfig: {
		DisplayName: Конфигурация поддержки модов

		Calamity: {
			Label: "[i/s1:1281] Новые ИИ режима Месть"
			Tooltip: Добавляет новые ИИ поддерживаемым боссам в режиме Месть.
		}

		Eternity: {
			Label: "[i/s1:3577] Новые ИИ режима Вечность"
			Tooltip: Добавляет новые ИИ поддерживаемым боссам в режиме Вечность.
		}

		Infernum: {
			Label: "[i/s1:2701] Инфернум считается режимом Вечность"
			Tooltip: Инфернум считается за режим Злоба + Вечность для боссов из поддерживаемых модов, у которых нет нового ИИ.
		}

		BossRush: {
			Label: "[i/s1:43] Поддержка Босс-раша"
			Tooltip:
				'''
				Добавляет поддерживаемых боссов в Босс-раш.
				ПРИМЕЧАНИЕ: Для добавления боссов необходимо включить соответствующие настройки поддержки модов ниже!
				'''
