Items: {
	ArcaneQuiver: {
		DisplayName: Волшебный колчан
		Tooltip:
			'''
			Урон стрел зависит от дебаффа [cbuff:ManaSickness]
			Оружие, использующее стрелы, теперь расходует ману, чтобы зачаровывать стрелы, увеличивая их урон
			Увеличивает урон стрел соразмерно количеству оставшейся маны
			Конвертирует любые стрелы в волшебные, если видимость аксессуара включена
			Значительно увеличивает скорость стрел
			Даёт 20% шанс не потратить стрелы
			'Magi conjured arcane arrows to sell to hunters, until hunters learned just enough magic to do it themselves'
			'''
	}

	EvilMushroom: {
		DisplayName: Злобный гриб
		Tooltip: Попадание по врагу накладывает и на вас и на врага дебафф [cbuff:CalamityMod/MarkedForDeath]
	}

	FastHolster: {
		DisplayName: Быстрая кобура
		Tooltip:
			'''
			Увеличивает скорострельность на 10%
			Снижает шанс стрелкового критического удара на 4%
			'Не беспокойся о своей точности. Главное - просто стреляй, а там уже и попадёшь в кого-нибудь!'
			'''
	}

	GrapeLauncher: {
		DisplayName: Suspended Shotgun Shell Launcher
		Tooltip: Fire a series of bullets after hit enemy 8 times in a row
	}

	InfectedCrabGill: {
		DisplayName: Инфицированные крабовые жабры /*Infected Crab Gill*/
		Tooltip:
			'''
			Summons spores over time that will damage enemies
			Guns have a chance to fire extra fungal round that splits on death.
			Decrease life regeneration by 1
			'''
	}

	LifeMushroom: {
		DisplayName: Live Mushroom
		Tooltip: Mushroom randomly grow around you, picking up to restore 15 life
	}

	MarvelousMycelium: {
		DisplayName: Marvelous Mycelium
		Tooltip:
			'''
			6% increased ranged damage and 9% increased ranged critical strike chance
			Being hit removes these benefit for a short time and gives you Mushy
			"Death goes life on, and life achieves death soon"
			'''
	}

	ModifiedCoil: {
		DisplayName: Modified Coil
		Tooltip:
			'''
			7% increased ranged damage
			Slightly increases the velocity of ranged projectiles
			"Exposed wires, handle carefully"
			'''
	}

	MushroomUnitedNations: {
		DisplayName: Mushroom United Nations
		Tooltip:
			'''
			Reduced defense by 5 and life regeneration by 2，15% increased ranged damage and 5% increased ranged critical strike chance
			The above effect is briefly reversed after taking damage
			Summons spores over time that will damage enemies
			Guns have a chance to fire extral fungal round that splits on death
			Being hit removes these benefit for a short time and gives you Mushy
			Press [KEY] to activate Trripy buff
			A mushroom sniper rifle hovers above your head, sniping the enemy farthest from you in range
			Reducing chance for enemies to target you
			"Why do I feel that our members are getting fewer and fewer?"
			'''
	}

	OdddMushroom: {
		DisplayName: Odd Mushroom
		Tooltip:
			'''
			Press [KEY] to activate Trripy buff
			"You can't always trust what you see."
			'''
	}

	SuperCoil: {
		DisplayName: Adamantite Coil
		Tooltip:
			'''
			Increased ranged critical strike chance based on your held weapon's use speed
			Moderately increases the velocity of ranged projectiles
			'''
	}

	TitaniumCoil: {
		DisplayName: Titanium Coil
		Tooltip:
			'''
			Increased ranged damage based on your held weapon's use speed
			Moderately increases the velocity of ranged projectiles
			'''
	}

	WulfrumCoil: {
		DisplayName: Wulfrum Coil
		Tooltip:
			'''
			7% increased ranged damage
			Slightly increases the velocity of ranged projectiles
			'''
	}

	AstralArrow: {
