	Homochromia: {
		DisplayName: Гомохромия
		Tooltip:
			'''
			90% шанс не потратить боеприпасы
			'Никак не связанно с вашей гомосексуальностью'
			'''
	}

	Nystagmus: {
		DisplayName: Нистагм
