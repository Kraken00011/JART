"Keybinds.Polypebral Dash.DisplayName": Полипебральный рывок

Items: {
	chainSaw: {
		DisplayName: Бензо-пила
		Tooltip:
			'''
			Попадание по врагу накапливает заряд, постепенно ослепляющий вас, но увеличивающий шанс критического удара.
			Нажмите ПКМ с хотя бы каким-то уровнем заряда, чтобы выстрелить несколькими глазами и использовать весь заряд
			Не увеличивает шанс критического удара от соответствующих бонусов
			'Бензо-ПИЛА!.. ну вы типа поняли, ПИЛА!.....'
			'''
	}

	FusedEye: {
		DisplayName: Сросшийся глаз
		Tooltip:
