		Tooltip: При каждом 3 взмахе выпускает самонаводящиеся снаряды теневого пламени
	}

	TetherBlade: {
		DisplayName: Tetherblade
		Tooltip:
			'''
			Throw the blade towards the cursor by <right>ing
			The blade will linger for a few seconds after throwing it
			<right> again to teleport to the blade before the blade disapears
			After teleporting the blade will stab at all nearby enemies, dealing triple damage
			'''
	}

	LightChain: {
		DisplayName: Luminant Tether
		Tooltip:
			'''
			Clicking an enemy links it to a player
			The chains deal damage once every second
			If you move to far away from the target you are chained to, the chain will break
			Up to 3 enemies can be chained to you
			'''
	}

	StormCrossbow: {
		DisplayName: Арбалет громобоя
		Tooltip: Конвертирует деревянные стрелы в громовые болты, отскакивающие от врага к врагу
	}

	ObsidianSickle: {
		DisplayName: Обсидиановый серп
		Tooltip:
			'''
			Стреляет тёмным серпом
			'Не искусственный интеллект, а простой придурок'
			'''
	}

	StarScepter: {
		DisplayName: Звёздный скипетр
		Tooltip:
			'''
			Призывает до 5 вращающихся вокруг игрока звёзд
			Каждая призванная звезда постоянно атакует ближайшего игрока
			Боссы находятся в большем приоритете
			'''
	}

	IlluminantCross: {
		DisplayName: Сверкающий крест
		Tooltip:
			'''
			Заряжает шквал сверкающего света в позиции курсора
			Зарядка шквала значительно увеличивает его размер и урон
			Полностью заряженные шквалы исцеляют союзников и выпускают 3 сверкающих болта
			'''
	}

	GlowstringBiwa: {
		DisplayName: Яркострунная бива
		Tooltip: Стреляет 2 сверкающими сферами, соединёнными струнной света
	}

	StormCarver: {
		DisplayName: Выкорчёвыватель штормов
		Tooltip:
			'''
			Вместо раскручивания взмахивает косой по диагонали
			Выпускает штормовой вихрь при столкновении с блоками
			'Врежь по земле!'
			'''
	}

	GrandAmplifier: {
		DisplayName: Великий усилитель
		Tooltip:
			'''
			Нажмите ЛКМ, чтобы выстрелить небольшой молнией, накладывающей дебафф [rbuff:Electrified]
			Нажмите ПКМ, чтобы призвать мощную молнию над всеми ближайшими врагами, поражёнными дебаффом [rbuff:Electrified]
			Эти молнии рассеивают дебафф [rbuff:Electrified], но наносят каскад из большого количества урона
			'''
	}

	PocketConcert: {
		DisplayName: И-ПМА Мехаматон
		Tooltip:
			'''
			Выпускает разноцветные музыкальные ноты
			Музыкальные ноты накладывают различные дебаффы в зависимости от цвета ноты
			Выпускает до 5 дополнительных нот за каждое уникальное усиление 2 уровня и выше, наложенное на вас
			[c/1FFBFF:'Однажды я отправился на поиски «Ордена воинов», зовущих себя трекерами. Когда я всё-таки сумел их найти,]
			[c/1FFBFF:одно из первых, что они показали мне - особый инструмент, похожий на музыкальную ноту, но с чем-то вроде рта.]
			[c/1FFBFF:Как бы то ни было, мне удалось превратить его в оружие, улучшающееся от количества усилений того, кто его использует.]
			[c/1FFBFF:Однако из-за этого мне пришлось сделать его намного... намного больше изначального варианта.']
			'''
	}

	GammaKnife: {
		DisplayName: С-ГСС Гамма-клинок
		Tooltip:
			'''
			Игнорирует 15 ед. защиты
			Нажмите ЛКМ, чтобы совершить взмах клинком по диагонали, выпускающий мощный шлейф гамма-излучения
			Шлейф наносит колоссальный урон на ближней дистанции, но со временем ослабевает, снижая свой урон и размер
			Нажмите ПКМ, чтобы бросить клинок, взрывающийся при попадании по блоку или врагу
			Во время броска клинок нельзя использовать
			'''
	}

	MiniaturizedRequiemEngine: {
		DisplayName: Миниатюрный реквием-двигатель
		Tooltip: Нажмите ПКМ, чтобы переключаться между 3 разными режимами атаки
	}

	MagicPurpleBouncyBalls: {
		DisplayName: 27 магических прыгучих фиолетовых шаров
		Tooltip: "'Фиолетовая энергия, пульсирующая силой 27 одновременных ошибок'"
	}

	GarudaWings: {
		DisplayName: Крылья Гаруды
		Tooltip: "'Крылья божественного наездника'"
	}

	ThunderboltActionSniperVoid: {
		DisplayName: Thunderbolt-Action Sniper Rifle
		Tooltip:
			'''
			Shoots a powerful, high velocity bullet
			Also fires a lightning bolt imbued with void energy
			<right> to zoom out
			'''
	}

	ThunderboltActionSniper: {
		DisplayName: Thunderbolt-Action Sniper Rifle
		Tooltip:
			'''
			Shoots a powerful, high velocity bullet
			Also fires a lightning bolt imbued with void energy
			<right> to zoom out
			'''
	}

	AllSeersGlass: {
		DisplayName: Линза всевидящего
		Tooltip:
			'''
			Увеличивает шанс критического удара на 10%
			Увеличивает урон критических ударов
			Увеличивает максимальное количество стражей на 2
			Grants a greater zoom passively
			Zoom effect can disabled with accessory visability
			Pressing the '{$Keybinds.AccessoryAbility.DisplayName}' key will freeze the camera in place
			'I see a unbreakable fortress in your future'
			'''
	}

	SwordofaThousandTruths: {
		DisplayName: Меч тысячи правд
		Tooltip:
			'''
			Нажмите ЛКМ, чтобы взмахнуть мечом, восстанавливающим 7 ед. здоровья при попадании по врагу
			Удерживайте ПКМ, чтобы зарядить и бросить вонзающийся во врагов меч
			Когда меч вонзается, он начинает испускать светлую и тёмную энергию
			Светлая энергия самонаводится на ближайших союзников и исцеляет здоровье на величину, равную вашему бонусному исцелению
			Тёмная энергия самонаводится на ближайших врагов, нанося им урон
			Если бонусное исцеление игрока больше либо равно 5 ед., тёмная энергия начнёт накладывать различные на врагов различные ослабляющие дебаффы
			Одновременно можно бросить только 1 меч
			'Простите, свинюшки, но эта жертва крайне важна'
			'''
	}

	AbsoluteTVRemote: {
		DisplayName: Всевышний пульт от телика
		Tooltip:
			'''
			Нажмите ЛКМ, чтобы вызвать ауру вокруг вас, замедляющую снаряды в определённом радиусе; можно использовать раз в 2 минуты
			Нажмите ПКМ, чтобы вызвать ауру вокруг вас, ускоряющую снаряды в определённом радиусе; можно использовать раз в 2 минуты
			Нажмите '{0}', чтобы выстрелить снарядом, останавливающим врагов на месте; можно использовать раз в 5 минут
			'Телевидение будет жить вечно!'
			'''
	}

	PlanetShaper: {
		DisplayName: Планеторез
		Tooltip:
			'''
			Вместо раскручивания коса взмахивает по диагонали
			Имеет комбо из 3 взмахов:
			При каждом 1 взмахе коса стреляет 1 самонаводящимся огненным шаром и 2 лучами космической энергии
			При каждом 2 взмахе коса стреляет 1 лучом космической энергии и 2 самонаводящимися огненными шарами
			При каждом 3 взмахе коса прокручивается вокруг игрока
			Во время раскручивания коса выпускает до 6 самонаводящихся огненных шаров и лучей космической энергии
			Коса и огненные шары игнорируют 125 ед. защиты и накладывают дебафф [cbuff:CalamityMod/Dragonfire]
			Лучи космической энергии игнорируют 75 ед. защиты и накладывают дебаффы [cbuff:CalamityMod/ElementalMix] и [cbuff:CatalystMod/AstralBlight]
			'ДАМЫ И ГОСПОДА... А СЕЙЧАС У НАС ПРОГРАММЕ... РОК'Н РОЛЛ!!!'
			'''
	}

	GodsPitch: {
		DisplayName: Божественный звук
		Tooltip:
			'''
			Увеличивает максимальный запас вдохновения на 5
			Увеличивает симфонический урон на 15%
			Симфонические усиления длятся на 3 секунды дольше
			Увеличивает уровень накладываемых усилений себе и всем союзникам на 2
			Увеличивает радиус действия усилений
			Атаки инструментами запускают падающие сверху вниз трубы
			[c/FF232C:Звуки, издаваемые трубами, могут показаться довольно неприятными, пугающими или даже отталкивающими]
			'Ваши уши не достойны слышать нечто подобное...'
			'''
	}

	GauntletofAnnihilationVoid: {
		DisplayName: Рукавица изничтожения
		Tooltip:
			'''
			Нажмите ЛКМ, чтобы выпустить каскад из 4 космических рукавиц, накладывающих дебафф [cbuff:CalamityMod/GodSlayerInferno]
			Нажмите ПКМ, чтобы начать выпускать стремительные удары космической энергии, запускающие вас вперёд в направлении курсора
			Выпад вперёд тратит лишь половину пустоты от стоимости использования и при столкновении отбрасывает вас назад
			Нажатие ЛКМ не более чем через 3 кадра после получения урона выпустит рукавицу богоубийцы
			Рукавица богоубийцы всегда наносит критический урон и накладывает дебафф [cbuff:CalamityMod/WhisperingDeath]
			Становится источником света, если отмечена как «Избранное»
			'''
	}

	GauntletofAnnihilation: {
		DisplayName: Рукавица изничтожения
		Tooltip:
			'''
			Нажмите ЛКМ, чтобы выпустить каскад из 4 космических рукавиц, накладывающих дебафф [cbuff:CalamityMod/GodSlayerInferno]
			Нажмите ПКМ, чтобы начать выпускать стремительные удары космической энергии, запускающие вас вперёд в направлении курсора
			Выпад отбрасывает вас назад при столкновении с чем-либо
			Нажатие ЛКМ не более чем через 3 кадра после получения урона выпустит рукавицу богоубийцы
			Рукавица богоубийцы всегда наносит критический урон и накладывает дебафф [cbuff:CalamityMod/WhisperingDeath]
			Становится источником света, если отмечена как «Избранное»
			'''
	}

	BlightedBadge: {
		DisplayName: Прогнившая эмблема
		Tooltip:
			'''
			Удары истинного ближнего боя вызывают падение астральных звёзд с небес
			Атакующие ошеломляются, получая огромный урон
			При получении урона кратковременно значительно увеличивает скорость атаки и шанс критического удара ближнего боя,
			а также вызывает взрыв и временно увеличивает урон истинного ближнего боя на 30%
			Длительность усилений зависит от количества полученного урона, вплоть до 10 секунд
			Даёт невосприимчивость к дебаффу [cbuff:CalamityMod/AstralInfectionDebuff]
			'''
	}

	ImagiknightHeraldry: {
		DisplayName: Рыцарство Imagiknight
		Tooltip:
			'''
			Множитель урона зависит от того, на сколько близко вы находитесь к врагам
			Максимальный бонус к урону: 20%
			Излучает пылающую ауру, увеличивающую урон ближайшим союзникам
			Чем ближе союзники к вам, тем больше увеличивается их множитель урона
			Эти множители не суммируются с множителями [i:CalamityMod/WarbanneroftheRighteous] Боевого знамя праведных; если оба предмета надеты, будет использоваться наибольший из имеющихся множителей
			Эффекты становятся более прозрачными и беззвучными, если отображение аксессуара отключено
			Увеличивает всем союзникам регенерацию здоровья на {0} ед./сек, максимальный запас здоровья на {1}%, сопротивление урону на {2}%, защиту на {3} ед. и урон на {4}%
			'Идея - простая частичка, прогрессивно ускоряющаяся соразмерно количеству прошедших сквозь неё умов.
			Если вам удастся собрать достаточное количество умов вместе, они смогут сделать названную идею неостановимой.' -Imagiknight_Girus
			'''
	}
}

ItemTooltip: {
	DuesFluteLore: Они обнаружили источник астральной инфекции и в попытке уничтожить его применили звёздное ядро к заражённому алтарю.
	DuesFluteLore2: Однако алтарь отреагировал неожиданно... два огонька начали отталкиваться друг от друга, устремляясь в небо и открыв над ним разлом.
	DuesFluteLore3: То, что вышло из него, поистине было не от мира сего, но их восхищению не суждено было продлиться - слуга звёзд бросился на них.
	UniversalLore1: Кос принял свой последний бой. Израсходовал все свои козыри. Он проиграл им. Однако это не значило, что Затмение сошло на нет.
	UniversalLore2: Используя всю силу, что таилась в его душе, он призвал истинного богоубийцу: Пожирателя богов.
	ParallelLore1: Как он и ожидал, они убили Штормового ткача. Но у Коса был припасен еще один туз в рукаве.
	ParallelLore2: Внезапно, безо всякого предупреждения, Кос переместил всех в зазеркалье и призвал своего второго слугу: Сигнуса.
	TwoSideLore1: Они преодолели Рагнарёк, уничтожили Затмение, пережили муссон слизи,
	TwoSideLore2: даже стояли на границе вечности, но лишь тогда Рен спросил их: «Какой путь вы изберёте?»
	NeonRipperLore1: После поражения Голиаф Эрелиан решил переработать часть броневых пластин, что тот носил.
	NeonRipperLore2: Так он создал два оружия: Первым стала коса, способная поглощать ауру, подобно способности Ками.
	PBGBardALore2: Так он создал два оружия: Вторым стала гитара, стреляющая разноцветными микроволнами.
	SearingSpearTip: 150% базового урона
	ArcticSpearTip: 115% базового урона
	VerveineItem: "'Предмет, благословлённый орхидеей...'"
	EngineGatling:
		'''
		Режим пулемёта:
		Удерживайте ЛКМ, чтобы значительно снизить разброс оружия и увеличить скорость атаки до максимума
		Выстрелы могут пробивать до 4 врагов
		'''
	EngineGatlingMode: ПУЛЕМЁТ
	EngineLaser:
		'''
		Режим лазера:
		Стреляет бесконечно пробивающим лазером, оставляющим наносящий урон шлейф
		Лазер может отскакивать от блоков до 3 раз
		'''
	EngineLaserMode: ЛАЗЕР
	EngineTheBigOne:
		'''
		Режим «Большой малый»:
		Стреляет колоссальной сферой концентрированной энергии, взрывающейся через определённое время
		Чем ближе враг к центру взрыва, тем больше урона он получит
		Одновременно может существовать только 1 «Большой малый»
		'''
	EngineTheBigOneMode: БОЛЬШОЙ МАЛЫЙ
	Playtester: - Предмет тестировщика -
	Contributor: - Предмет участника -
	Donor: - Предмет покровителя -
	DedTo: - Посвящён игроку {0} -

	Dedicated: {
