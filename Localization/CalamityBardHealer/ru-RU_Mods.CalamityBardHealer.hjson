Buffs: {
	AlluringSong: {
		DisplayName: Манящая песнь
		Description:
			'''
			Скорость восстановления вдохновения и радиус действия усилений увеличены на 50%
			Усиления длятся на 5 секунд дольше
			Получение урона исцеляет вас на 250 ед. здоровья, но деактивирует бафф
			'Идеальная мелодия, чтобы подкатить к паре элеметальных чикс'
			'''
	}

	AlluringSongCD: {
		DisplayName: Перезарядка манящей песни
		Description:
			'''
			Вы не можете использовать манящую песнь
			'Этот бро НЕ приготовил'
			'''
	}

	CalamityBell: {
		DisplayName: Бедственный колокол
		Description: Так и ждёт своего часа...
	}
}

Configs: {
	BalanceConfig: {
		DisplayName: Конфигурация баланса

		expensiveDraedonsForge: {
			Label: Удорожание кузни Дрэйдона
			Tooltip: Кузня Дрэйдона будет требовать в создании редкие материалы из Thorium.
		}

		rogueThrowerMerge: {
			Label: Объединить класс разбойника с метателем
			Tooltip: Автоматически отключается, если мод Ragnarok включён.
		}

		showItemChanges: {
			Label: Отображение изменения предметов
			Tooltip: Включает/Выключает отображение строки «Этот предмет изменён модом» в описании изменённых этим модом предметов.
		}

		defenseDamage: {
			Label: Урон по защите у врагов Thorium
			Tooltip: Включает/Выключает урон по защите у врагов из мода Thorium.
		}

		convertItems: {
			Label: Смена классов для предметов Calamity в классы мода Thorium
			Tooltip:
				'''
				Конвертирует некоторые предметы Calamity в предмета класса бард и целитель.
				Может немного перерабатывать соответствующие предметы, чтобы они лучше соответствовали своему новому классу.
				Изменённые предметы:
				-[i:CalamityMod/AnahitasArpeggio] {$Mods.CalamityMod.Items.Weapons.Magic.AnahitasArpeggio.DisplayName} -> Струнный инструмент, поведение переработано.
				-[i:CalamityMod/BelchingSaxophone] {$Mods.CalamityMod.Items.Weapons.Magic.BelchingSaxophone.DisplayName} -> Медный инструмент.
				-[i:CalamityMod/FaceMelter] {$Mods.CalamityMod.Items.Weapons.Magic.FaceMelter.DisplayName} -> Гибрид электрического и струнного инструмента, поведение переработано.
				-[i:CalamityMod/RelicOfConvergence] {$Mods.CalamityMod.Items.Tools.RelicOfConvergence.DisplayName} -> Исцеляющее заклинание, базовое количество исцеления увеличено, чтобы быть на том же уровне по силе, что и другие заклинания.
				'''
		}

		bard: {
			Label: Множитель урона симфонического оружия
			Tooltip:
				'''
				Увеличивает урон симфонического оружия из этого мода под заданный множитель
				(Для лучшей работы этой настройки требуется перезайти в мир!)
				'''
		}

		radiant: {
			Label: Множитель урона лучезарного оружия
			Tooltip:
				'''
				Увеличивает урон лучезарного оружия из этого мода под заданный множитель
				(Для лучшей работы этой настройки требуется перезайти в мир!)
				'''
		}

		soulEssence: {
			Label: Множитель количества эссенций души
			Tooltip:
				'''
				Увеличивает количество получаемых эссенций души с использованием лучезарного оружия из этого мода под заданный множитель
				Максимальное количество эссенций души, которое можно получить: 5
				(Для лучшей работы этой настройки требуется перезайти в мир!)
				'''
		}

		healing: {
			Label: Множитель исцеления
			Tooltip:
				'''
				Увеличивает количество исцеления лучезарных заклинаний из этого мода под заданный множитель
				Значение 0 означает, что заклинания будут исцелять только 1 ед. здоровья
				(Для лучшей работы этой настройки требуется перезайти в мир!)
				'''
		}
	}
}
