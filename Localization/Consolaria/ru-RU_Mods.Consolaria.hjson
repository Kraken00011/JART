				smallEventsEnabled: {
					Label: Ограничить мелкие события по системной дате
					Tooltip: При включении определенные предметы и враги будут появляться только в соответствующие праздники, или после использования Кости Желаний.
				}

				vanillaBossMusicEnabled: {
					Label: Включить ванильную музыку для боссов из Consolaria
					Tooltip: При включении музыкальные треки из мода будут заменены на те, что были изначально использованы в консольных версиях.
				}

				tizonaZenithIntegrationEnabled: {
					Label: Добавление Тизоны в рецепт создания Зенита
					Tooltip: Включает/Выключает добавление Тизоны в рецепте создания Зенита, а также её отображение как одного из снарядов Зенита.
				}

				oktoberLocksEnabled: {
