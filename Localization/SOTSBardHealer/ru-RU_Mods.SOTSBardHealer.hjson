Configs: {
	BalanceConfig: {
		DisplayName: Конфигурация баланса

		thrower: {
			Label: Множитель урона оружия метателя
			Tooltip:
				'''
				Увеличивает урон метательного оружия из этого мода под заданный множитель
				(Для лучшей работы этой настройки требуется перезайти в мир!)
				'''
		}

		bard: {
			Label: Множитель урона оружия барда
			Tooltip:
				'''
				Увеличивает урон симфонического оружия из этого мода под заданный множитель
				(Для лучшей работы этой настройки требуется перезайти в мир!)
				'''
		}

		radiant: {
			Label: Множительно урона оружия целителя
			Tooltip:
				'''
				Увеличивает урон лучезарного оружия из этого мода под заданный множитель
				(Для лучшей работы этой настройки требуется перезайти в мир!)
				'''
		}

		soulEssence: {
			Label: Множитель количества эссенций души
			Tooltip:
				'''
				Увеличивает количество получаемых эссенций души с использованием лучезарного оружия из этого мода под заданный множитель
				Максимальное количество эссенций души, которое можно получить: 5
				(Для лучшей работы этой настройки требуется перезайти в мир!)
				'''
		}

		healing: {
			Label: Множитель исцеления
			Tooltip:
				'''
				Увеличивает количество исцеления лучезарных заклинаний из этого мода под заданный множитель
				Значение 0 означает, что заклинания будут исцелять только 1 здоровье
				(Для лучшей работы этой настройки требуется перезайти в мир!)
				'''
		}

		voidCost: {
			Label: Расход пустоты
			Tooltip:
				'''
				Увеличивает расход пустоты для предметов из этого мода под заданный множитель
				(Для лучшей работы этой настройки требуется перезайти в мир!)
				'''
		}
	}
}
