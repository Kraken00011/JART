Items: {
	ImpulseAmplifier: {
		DisplayName: Импульсный усилитель
		Tooltip:
			'''
			Значительно увеличивает скорость снарядов электронных инструментов и даёт им возможность накладывать дебафф [cbuff:Electrified] при первом попадании по врагу
			Снаряды электронных инструментов вызывают цепную молнию, наносящую 10% урона атаки при первом попадании по врагу
			'''
	}
	
	FanDonations: {
		DisplayName: Пожертвования фанатов
		Tooltip:
			'''
			Все атаки симфонических инструментов вызывают случайного размера взрыв, наносящий на 50% меньше урона от критического удара
			Пронзающие снаряды струнных инструментов увеличивают свою скорость за каждого пронзённого насквозь врага и больше не снижают свой урон
			Определённые атаки струнных инструментов, активирующие свои эффекты при попадании по блоку, также активируют его и при попадании по врагу
			Атаки ударных инструментов запускают вверх падающие молоточки
			Значительно увеличивает скорость снарядов электронных инструментов и даёт им возможность накладывать дебафф [cbuff:Electrified] при первом попадании по врагу
			Снаряды электронных инструментов вызывают цепную молнию, наносящую 10% урона атаки при первом попадании по врагу
			Увеличивает максимальный запас вдохновения на 5
			'''
	}

	LunateCharm: {
		DisplayName: Амулет полумесяца
		Tooltip: Снимает штраф на весь урон, кроме лучезарного, от брони целителя и на лучезарный урон от дебаффа [cbuff:InfernalEclipseAPI/BrokenOath]
	}

	SealedContract: {
		DisplayName: Заключённый договор
		Tooltip:
			'''
			Увеличивает максимальный запас здоровья на 60
			Исцеляющие заклинания восстанавливают дополнительно 5 ед. здоровья
			Снимает штраф на весь урон, кроме лучезарного, от брони целителя и на лучезарный урон от дебаффа [cbuff:InfernalEclipseAPI/BrokenOath]
			Получение эссенций души, используя лучезарные косы, даёт 1 стак агрегатного заряда
			Нанесение лучезарного урона снарядами кос или любым лучезарным оружием, кроме кос, использует накопленный агрегатный заряд, давая эссенции души
			'Сделке - быть!'
			'''
	}
}

