Buffs: {
	NinjaBuff.Description: Скорость метательных снарядов увеличена на 20% и шанс метательного критического удара увеличен на 10%
	BloodRush.Description: Скорость добычи увеличена на 15%
}

Items: {
	CapeoftheSurvivor: {
		DisplayName: Плащ выжившего
		Tooltip:
			'''
			'The very fabric of this cape has been designed to guide you through the toughest days'
			You quickly gain up to 15% damage reduction over time
			Getting hit briefly reduces this bonus to -10% damage reduction
			While this bonus is above 0%, you gain up to 2 life recovery
			'''
	}

	ShootingStarHat.SetBonus:
		'''
		Симфонические усиления длятся на 6 секунд дольше
		Каждое уникальное усиление, наложенное на вас, увеличивает симфонический урон на 2,5% и скорость восстановления вдохновения на 2%
		'''

	SoulofPlight: {
		DisplayName: Эссенция гнева
		Tooltip: "'Эссенция проклятых существ'"
