	KeyofPlight: {
		DisplayName: Ключ гнева
		Tooltip: "'Заряжен эссенциями множества душ'"
	}

	MasterMarksmansScouter.Tooltip:
		'''
		'Порох отсеет слабых'
		Ближайший враг становится объектом наблюдения и получает на 10% больше урона от всех источников
		Стрелковый урон накладывает на врагов дебафф [cbuff:CursedInferno]
		'''
	AssassinsGuard.Tooltip:
		'''
		Увеличивает стрелковый урон на 16%
		Увеличивает шанс стрелкового критического удара на 15%
		Даёт 25% шанс не потратить боеприпасы
		'''

	Kinetoscythe: {
		DisplayName: Кинето-коса
		Tooltip:
			'''
			Стремительно вращает вокруг вас высокотехнологичную косу
			Нажмите ПКМ, чтобы создать неподвижную вращающуюся энергетическую косу
			Вращайте косу пока энергетическая коса активна, чтобы заставить её самонаводиться на ближайших врагов
			'''
	}

	BlackMIDI: {
		DisplayName: Чёрный MIDI-синтезатор
		Tooltip:
			'''
			Стремительно выпускает каскад шумов в направлении курсора
