			'''
	}

	ShieldConduit: {
		DisplayName: Щитовой проводник
		Tooltip:
		    '''
			2 ед. урона от метки призывателя
			Автоматически переключается между 2 режимами
			'''
		HoldShiftTooltip:
			'''
			-----------------------------
			Режим защиты:
			Попадание по врагу хлыстом заставляет миньонов кратковременно выпускать синие щитовые осколки
			Подбор осколков заряжает щит
			При достижении 50 ед. заряда вы получаете щит на 50 ед. здоровья
			-----------------------------
			Режим атаки:
			Попадание по врагу хлыстом заставляет миньонов кратковременно выпускать красные самонаводящиеся щитовые осколки,
			наносящие 10% урона миньона и 3 ед. дополнительного урона
			-----------------------------
			Выпуск осколков имеет очень короткую перезарядку
			Если щит получит урон, он уйдёт на перезарядку, длительностью от 5 до 50 секунд в зависимости от оставшегося здоровья щита
			Если щит полностью ломается, он уходит на 60-секундную перезарядку
			Во время перезарядки режим меняется на режим атаки
			По окончании перезарядки режим обратно меняется на защитный
			Если у щита остаётся прочность, то подбор осколков восполнит её часть
			'''
	}

