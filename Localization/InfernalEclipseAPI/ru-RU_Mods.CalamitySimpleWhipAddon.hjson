			'''
	}

	MandibleLash: {
		DisplayName: Жвальный хлыст
		Tooltip:
			'''
			1 ед. урона от метки призывателя
			Во всех врагов, поражённых ударом хлыста, запускается песочный шар при следующем попадании миньона, падающий от гравитации и наносящий 40% от урона миньона
			Песочный шар взрывается при столкновении, нанося урон врагам по близости
			'''
	}

	DarkMandibleLash: {
		DisplayName: Тёмный жвальный хлыст
		Tooltip:
			'''
			2 ед. урона от метки призывателя
			Во всех врагов, поражённых ударом хлыста, запускается песочный шар при следующем попадании миньона, падающий от гравитации и наносящий 40% от урона миньона
