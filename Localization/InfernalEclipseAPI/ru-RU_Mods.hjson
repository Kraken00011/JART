				'''
				Модифицирует пару предметов из Calamity, которые были слишком слабыми/сильными.
				Также изменяет парочку кросс-модовых рецептов для лучшего баланса между модами.
				'''
		}

		BossKillCheckOnOres: {
			Label: Сохранение уровневой прогрессии Calamity
			Tooltip:
