		}

		InfernumModeForced: {
			Label: Блокировка меню выбора сложностей Calamity
			Tooltip:
				'''
				Блокирует доступ к меню выбора сложностей Calamity, даже вне битв с боссами.
				Перед включением обязательно убедитесь, что включили нужную сложность.
