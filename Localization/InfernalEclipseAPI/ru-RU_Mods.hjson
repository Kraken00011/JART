			Tooltip: Отключает создание зелий с использованием кровавых сфер.
		}

		PreventBossCheese: {
			Label: Предотвращение чизинга боссов
			Tooltip: Добавляет несколько механик в игру для предотвращения использования некоторых способов, облегчающих убийство босса.
		}

		DisableUnfinisedContent: {
			Label: Отключение недоработанного контента
			Tooltip: Отключает любой незаконченный контент из других модов для того, чтобы игрок получал полноценный игровой опыт.
		}

		DisableDuplicateContent: {
			Label: Удаление дублирующего контента
			Tooltip: Удаляет любой дублирующийся контент, который добавляют разные моды.
		}

		AdditonalVanillaBossAdjustments: {
			Label: Изменения ванильных боссов
			Tooltip: Немного меняет характеристики паре ванильных боссов, чтобы они были более сложными.
		}

		MergeCraftingTrees: {
			Label: Объединение деревьев крафтов
			Tooltip: Объединяет деревья крафтов, схожих между собой предметов из разных модов и добавляет собственные кросс-модовые рецепты некоторым предметам.
		}

		BloodOrbPotionDuplication: {
			Label: Дублирование зелий при помощи кровавых сфер
			Tooltip: Заменяет рецепты создание зелий из кровавых сфер на простое их дублирование.
		}

		ChanageWeaponClasses: {
			Label: Смена класса некоторого оружия
			Tooltip: Меняет класс некоторого оружия, добавляя больше вариативности и смысла оружию.
		}

		DisplayWorldEntryMessages: {
			Label: Сообщение при входе в мир
			Tooltip: Включает/Выключает сообщение, появляющееся при заходе в мир.
		}

		EnableInterlude4: {
			Label: Проигрывание 4 интерлюдий
			Tooltip:
				'''
				Включает/Выключает тему 4 интерлюдий. 
				Эти интерлюдия проигрываются после победы над Экзо-механизмами и Серной ведьмой вместо «Their Fabricator» и «Acceptance».
				'''
		}

		AdjustAdvisorSpawnConditions: {
			Label: Изменение условий призыва Аналитика
			Tooltip:
				'''
				Меняет условия для призыва Аналитика так, чтобы возможность его призвать была доступна не постоянно
				Особенно полезно, если вы играете с Infernum, так как в ином случае его шкала здоровья будет отображаться всегда, поскольку Аналитик всегда жив.
				Может вызывать проблемы при игре в мультиплеере, поэтому советуем отключать эту опцию, когда вы играете в мультиплеере.
				'''
		}

