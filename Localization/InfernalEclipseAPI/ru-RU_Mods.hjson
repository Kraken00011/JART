	Lycanroc: {
		DisplayName: Ликанрок
		Tooltip: ""

		Progression: {
			WoF:
				'''
				Победите хранителя преисподней для получения большей силы...
				Новая сила ещё не получена...
				'''
			Mechs:
				'''
				С победой над Стеной плоти выстрелы начали накладывать дебафф [cbuff:CalamityMod/Crumbling]
				Победите механических чудовищ для получения большей силы...
				'''
			Plantera:
				'''
				С победой над механизмами Дрэйдона оружие начало конвертировать обычные пули в высокоскоростные
				Победите хранителя джунглей для получения большей силы...
				'''
			Golem:
				'''
				С победой над Плантерой ваша ярость заставляет оружие стрелять с неимоверной скоростью
				Победите конструкцию Храма джунглей для получения большей силы...
				'''
			Cultist:
				'''
				С победой над Големом ваш адреналин заставляет все выстрелы наносить критический урон
				Победите лидера древнего культа для получения большей силы...
				'''
			MoonLord:
				'''
				С победой над Культистом-лунатиком оружие получило шанс нанести сверхкритический удар
				Победите ужас из космоса для получения большей силы...
				'''
			Full: Ликанрок полностью пробудился, и его полная сила была высвобождена!
		}

		Lore: "'И что ты сделаешь? Вот так просто прикончишь меня?'"
	}

	CelestialIllumination: {
		DisplayName: Внеземное озарение
		Tooltip: ""

		Progression: {
			Deus:
				'''
				Победите ужас из космоса для получения большей силы...
				Новая сила ещё не получена...
				'''
			MoonLord:
				'''
				С победой над Лунным лордом книга начала стрелять большим количеством звёзд
				Победите хранителей осквернённого пламени для получения большей силы...
				'''
			Providence:
				'''
				С победой над Провиденс небесный сила небесного луча увеличилась
				Победите слуг пожирателя для получения большей силы...
				'''
			Polterghast:
				'''
				С победой над Полтергастом книга начала стрелять небесным лучом
				Победите Пожирателя богов для получения большей силы...
				'''
			DoG:
				'''
				С победой над Пожирателем богов ваши звёзды начали самонаводиться на врагов
				Победите пылкого феникса для получения большей силы...
				'''
			Full: Внеземное озарение полностью пробудилось, и его полная сила была высвобождена!
			ProfanedGuardians:
				'''
				С победой над Осквернёнными стражами книга начала стрелять небесным лучом
				Победите Богиню пламени для получения большей силы...
				'''
			Sentinels:
				'''
				С победой над слугами небесный луч стал атаковать дольше
				Победите Пожирателя богов для получения большей силы...
				'''
		}

		Lore: Последняя книга, написанная тем, кто носит клеймо Астры...
	}

