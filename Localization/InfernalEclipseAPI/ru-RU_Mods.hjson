	StellarSabre: {
		DisplayName: Неземная сабля
		Tooltip: ""

		Progression: {
			WoF:
				'''
				Победите хранителя преисподней для получения большей силы...
				Новая сила ещё не получена...
				'''
			Mechs:
				'''
				С победой над Стеной плоти ваш меч стал стрелять большим количеством звёзд
				Победите механических чудовищ для получения большей силы...
				'''
			Plantera:
				'''
				С победой над Механизмами Дрэйдона сабля стала накладывает дебафф «Астральная инфекция»
				Победите хранителя джунглей для получения большей силы...
				'''
			Golem:
				'''
				С победой над Плантерой звёзды сабли начали разделяться при попадании
				Победите древнюю конструкцию Храма джунглей для получения большей силы...
				'''
			Cultist:
				'''
				С победой над Големом звёзды сабли начали самонаводиться на врагов
				А также, со времен звёзды будут разделяться, если не найдут свою цель
				Победите лидера древнего культа для получения большей силы...
				'''
			MoonLord:
				'''
				С победой над Культистом-лунатиком звёзды сабли начали разрываться при попадании по врагу
				Победите ужас из космоса для получения большей силы...
				'''
			Full:
				'''
				Неземная сабля полностью пробудилась, а с этим, все её способности были значительно усилены
				Полная мощь оружия высвобождена!
				'''
		}

		Lore: "'Даже после всего случившегося, оставалось ещё одно существо, которое Ксандер отказывался атаковать...'"
	}

