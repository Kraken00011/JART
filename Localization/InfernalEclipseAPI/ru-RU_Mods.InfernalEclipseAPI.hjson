	Lycanroc: {
		DisplayName: Лайканрок
		Tooltip: ""

		Progression: {
			WoF:
				'''
				Одолейте хранителя преисподней, чтобы обрести больше силы...
				Новая сила ещё не была обретена...
				'''
			Mechs:
				'''
				С победой над Стеной плоти выстрелы начали накладывать дебафф [cbuff:CalamityMod/Crumbling]
				Одолейте механических чудовищ, бродящих во тьме, чтобы обрести больше силы...
				'''
			Plantera:
				'''
				С победой над механизмами Дрэйдона оружие начало конвертировать обычные пули в высокоскоростные
				Одолейте хищного хранителя джунглей, чтобы обрести больше силы...
				'''
			Golem:
				'''
				С победой над Плантерой ваша ярость заставляет оружие стрелять с неимоверной скоростью
				Одолейте древнюю конструкцию, построенную в самом сердце Храма джунглей, чтобы обрести больше силы...
				'''
			Cultist:
				'''
				С победой над Големом ваш адреналин заставляет все выстрелы наносить критический урон
				Одолейте лидера древнего культа Темницы, чтобы обрести больше силы...
				'''
			MoonLord:
				'''
				С победой над Культистом-лунатиком оружие получило шанс нанести сверхкритический удар
				Одолейте гнетущий ужас космоса, чтобы обрести больше силы...
				'''
			Full: Лайканрок полностью пробудился, и его истинная сила была полностью раскрыта!
		}

		Lore: "'И что ты сделаешь? Вот так просто прикончишь меня?'"
	}

	CelestialIllumination: {
		DisplayName: Внеземное озарение
		Tooltip: ""

		Progression: {
			Deus:
				'''
				Одолейте гнетущий ужас космоса, чтобы обрести больше силы...
				Новая сила ещё не была обретена...
				'''
			MoonLord:
				'''
				С победой над Лунным лордом книга начала стрелять большим количеством звёзд
				Одолейте хранителей осквернённого пламени, чтобы обрести больше силы...
				'''
			ProfanedGuardians:
				'''
				С победой над Осквернёнными стражами книга начала стрелять небесным лучом
				Одолейте Богиню осквернённого пламени, обитающую в скверных садах, чтобы обрести больше силы...
				'''
			Providence:
				'''
				С победой над Провиденс небесный сила небесного луча увеличилась
				Одолейте слуг Пожирателя, охраняющих его покой, чтобы обрести больше силы...
				'''
			Polterghast:
				'''
				С победой над Полтергастом книга начала стрелять небесным лучом
				Чтобы обрести больше силы, одолейте того, чья сила настолько велика, что он способен пожирать настоящих богов...
				'''
			Sentinels:
				'''
				С победой над слугами небесный луч начал атаковать дольше
				Чтобы обрести больше силы, одолейте того, чья сила настолько велика, что он способен пожирать настоящих богов...
				'''
			DoG:
				'''
				С победой над Пожирателем богов ваши звёзды начали самонаводиться на врагов
				Одолейте пылкого феникса эпохи драконов, чтобы обрести больше силы...
				'''
			Full: Внеземное озарение полностью пробудилось, а его истинная сила была полностью раскрыта!
		}

		Lore: Последняя книга, написанная тем, кто носит клеймо Астры...
	}

