		}

		WarMachineBossInBossRush: {
			Label: Вульфрумовый корабль-носитель в Босс-раше
			Tooltip: Добавляет Вульфрумовый корабль-носитель в Босс-раш.
		}

		MaxVoidOnRespawn: {
			Label: Возрождения с максимальным количеством пустоты
			Tooltip: Включает/Выключает увеличение количества пустоты, которое вы получаете при возрождении, до вашего лимита.
