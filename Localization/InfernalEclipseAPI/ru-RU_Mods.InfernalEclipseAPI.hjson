	StellarSabre: {
		DisplayName: Звёздная сабля
		Tooltip: ""

		Progression: {
			WoF:
				'''
				Одолейте хранителя преисподней, чтобы обрести больше силы...
				Новая сила ещё не была обретена...
				'''
			Mechs:
				'''
				С победой над Стеной плоти ваш меч стал стрелять большим количеством звёзд
				Одолейте механических чудовищ, бродящих во тьме, чтобы обрести больше силы...
				'''
			Plantera:
				'''
				С победой над механизмами Дрэйдона сабля стала накладывать дебафф [cbuff:CalamityMod/AstralInfectionDebuff]
				Одолейте хищного хранителя джунглей, чтобы обрести больше силы...
				'''
			Golem:
				'''
				С победой над Плантерой звёзды сабли начали разделяться при попадании
				Одолейте древнюю конструкцию, построенную в самом сердце Храма джунглей, чтобы обрести больше силы...
				'''
			Cultist:
				'''
				С победой над Големом звёзды сабли начали самонаводиться на врагов
				А также, с течением времени звёзды станут разделяться, если не смогут найти свою цель
				Одолейте лидера древнего культа Темницы, чтобы обрести больше силы...
				'''
			MoonLord:
				'''
				С победой над Культистом-лунатиком звёзды сабли начали разрываться при попадании по врагу
				Одолейте гнетущий ужас космоса, чтобы обрести больше силы...
				'''
			Full:
				'''
				Звёздная сабля полностью пробудилась, а с этим, все её способности были значительно усилены
				Полная мощь оружия высвобождена!
				'''
		}

		Lore: "'Даже после всего случившегося, оставалось ещё одно существо, которое Ксандер отказывался атаковать...'"
	}

	ExoSights: {
