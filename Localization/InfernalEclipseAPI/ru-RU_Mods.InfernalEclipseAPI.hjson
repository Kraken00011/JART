BossRushIntroText1:
	'''
	ИСПЫТАНИЕ КСЕРОКА
	АНСАМБЛЬ ШУТОВ
	'''

InfernumIntegration: {
	Astrageldon:
		'''
		ВСЕЛЕНСКИЙ ТЕРРОР
		АСТРАГЕЛЬДОН
		'''
	Clamitas:
		'''
		ВЫСШИЙ МОЛЛЮСК
		КАЛАМИДИЯ
		'''
	You:
		'''
		СКВЕРНОЕ ОТРАЖЕНИЕ
		ТЫ
		'''
	Polaris:
		'''
		МОРОЗНАЯ МАШИНА СМЕРТИ
		ПОЛЯРИС
		'''
	NewPolaris:
		'''
		МОРОЗНАЯ МАШИНА СМЕРТИ
		ПОЛЯРИС
		'''
	TrojanSquirrel:
		'''
		ДРЕВЕСНАЯ ЛОВУШКА
		ТРОЯНСКАЯ БЕЛКА
		'''
	CursedCoffin:
		'''
		ПАРАНОИДАЛЬНЫЙ ГРОБ
		ПРОКЛЯТЫЙ САРКОФАГ
		'''
	DeviBoss:
		'''
		ЛЮБВЕОБИЛЬНАЯ САДИСТКА
		ДЕВИАНТТ
		'''
	BanishedBaron:
		'''
		НЕПОКОРНЫЙ МЕХАНИЗМ
		ИЗГНАННЫЙ БАРОН
		'''
	LifeChallenger:
		'''
		ЛОРД ПИКСИ
		СВЕТ ЖИЗНИ
		'''
	TimberChampion:
		'''
		ИМПЕРАТОР ЛЕСА
		ЧЕМПИОН ЛЕСА
		'''
	TerraChampion:
		'''
		ТЕКТОНИЧЕСКИЙ ПРОНЫРА
		ЧЕМПИОН ПЛАНЕТЫ
		'''
	EarthChampion:
		'''
