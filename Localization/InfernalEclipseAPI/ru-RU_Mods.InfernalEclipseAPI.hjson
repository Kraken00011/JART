DiaryTooltip:
	'''
	[c/E3AF40:Загадочный дневник, написанный неизвестным...]
	[c/BEBEBE:Удерживайте Shift, чтобы прочесть его]
	'''
BullyingTooltip:
	'''
	Увеличивает весь урон, кроме урона призывателя, на 2% за каждый незанятый слот миньонов
	Снижает урон призывателя на 10% за каждый занятый слот миньонов
	Хлысты усиливаются от бонусов воина заместо бонусов призывателя
	Увеличивает урон хлыстов на 10%
	[c/E3AF40:Обрывок бумаги с микрочипом внутри, разработанный Диланом]
	[c/BEBEBE:Удерживайте Shift, чтобы прочесть предупреждение на обороте бумажки]
	'''

Configs: {
	InfernalConfig: {
		WrathoftheGodsBossesInBossRush: {
			Label: Боссы мода Wrath of the Gods в Босс-раше
			Tooltip: Добавляет ВГ-07 Марса, Воплощение пустоты и Безымянное божество в Босс-раш.
		}

		BetsyInBossRush: {
			Label: Бэтси в Босс-раше
			Tooltip: Добавляет Бэтси в Босс-раш. (КРАЙНЕ ЗАБАГОВАННО)
		}

		DreadnautillusInBossRush: {
			Label: Дреднаутилус в Босс-раше
			Tooltip: Добавляет Дреднаутилуса в Босс-раш.
		}

		Headers: {
			BossRushChanges: Добавление боссов в Босс-раш
			BalanceChanges: Изменения баланса
			Miscellaneous: Разное
			MultiplayerAdjustments: Изменения мультиплеера и другое
			Main: Основное
			Secret: Скрытые настройки
			Music: Музыка
		}

		ThoriumBalanceChangess: {
			Label: Изменения баланса Thorium
			Tooltip: Модифицирует множество предметов из Thorium и его аддонов для соответствия баланса с Calamity.
		}

		CalamityRecipeTweaks: {
			Label: Улучшения рецептов Calamity
			Tooltip: Меняет пару рецептов из Calamity и удаляет большинство облегчающих игру рецептов
		}

		CalamityBalanceChanges: {
			Label: Изменения баланса Calamity
			Tooltip:
				'''
				Модифицирует пару предметов из Calamity, которые были слишком слабыми/сильными.
				Также изменяет парочку кросс-модовых рецептов для лучшего баланса между модами.
				'''
		}

		BossKillCheckOnOres: {
			Label: Сохранение уровневой прогрессии Calamity
			Tooltip:
				'''
				Делает некоторые предметы невозможными к получению до прохождения до определённого этапа игры.
				Некоторые руды и блоки теперь недоступны к добыче до победы над определёнными боссами.
				'''
		}

		VanillaBalanceChanges: {
			Label: Изменения баланса ваниллы
			Tooltip: Изменяет пару ванильных предметов так, чтобы они соответствовали балансу Calamity.
		}

		DisplayName: Конфигурация

		TerraBladeBossInBossRush: {
			Label: Терра-клинок в Босс-раше
			Tooltip: Добавляет Терра-клинок в Босс-раш.
		}

		InfernumModeForced: {
			Label: Блокировка меню выбора сложностей Calamity
			Tooltip:
				'''
				Блокирует доступ к меню выбора сложностей Calamity, даже вне битв с боссами.
				Перед включением обязательно убедитесь, что включили нужную сложность.
				Полезно на серверах, если вам не хочется, чтобы другие меняли сложность игры.
				'''
		}

		SOTSBalanceChanges: {
			Label: Изменения баланса Secrets of the Shadows
			Tooltip: Изменяет пару предметов Secrets of the Shadows так, чтобы они соответствовали балансу Calamity.
		}

		ConsolariaBalanceChanges: {
			Label: Изменения баланса Consolaria
			Tooltip: Изменяет пару предметов Consolaria так, чтобы они соответствовали балансу Calamity.
		}

		InfernumRecipeTweaks: {
			Label: Улучшения рецептов Infernum
			Tooltip: Изменяет пару рецептов, добавляемых Infernum Mode.
		}

		ForceFullXerocDialogue: {
			Label: Проигрывание полного диалога Ксерока
			Tooltip: Заставляет диалог Ксерока проигрываться полностью, от начала и до конца, что при активации Босс-раша, что при его прохождении. Полезно на серверах.
		}

		SOTSThrowerToRogue: {
			Label: Смена класса пустотного метателя на пустотного разбойника
			Tooltip: Предметы, наносящие пустотный и метательный урон из Unofficial SOTS Bard, Thrower, and Healer начнут наносить пустотный и разбойный урон.
		}

		DisableBloodOrbPotions: {
			Label: Отключение создания зелий из кровавых сфер
			Tooltip: Отключает создание зелий с использованием кровавых сфер.
		}

		PreventBossCheese: {
			Label: Предотвращение чизинга боссов
			Tooltip: Добавляет несколько механик в игру для предотвращения использования некоторых способов, облегчающих убийство босса.
		}

		DisableUnfinisedContent: {
			Label: Отключение недоработанного контента
			Tooltip: Отключает любой незаконченный контент из других модов для того, чтобы игрок получал полноценный игровой опыт.
		}

		DisableDuplicateContent: {
			Label: Удаление дублирующего контента
			Tooltip: Удаляет любой дублирующийся контент, который добавляют разные моды.
		}

		AdditonalVanillaBossAdjustments: {
			Label: Изменения ванильных боссов
			Tooltip: Немного меняет характеристики паре ванильных боссов, чтобы они были более сложными.
		}

		MergeCraftingTrees: {
			Label: Объединение деревьев крафтов
			Tooltip: Объединяет деревья крафтов, схожих между собой предметов из разных модов и добавляет собственные кросс-модовые рецепты некоторым предметам.
		}

		BloodOrbPotionDuplication: {
			Label: Дублирование зелий при помощи кровавых сфер
			Tooltip: Заменяет рецепты создание зелий из кровавых сфер на простое их дублирование.
		}

		ChanageWeaponClasses: {
			Label: Смена класса некоторого оружия
			Tooltip: Меняет класс некоторого оружия, добавляя больше вариативности и смысла оружию.
		}

		DisplayWorldEntryMessages: {
			Label: Сообщение при входе в мир
			Tooltip: Включает/Выключает сообщение, появляющееся при заходе в мир.
		}

		EnableInterlude4: {
			Label: Проигрывание 4 интерлюдий
			Tooltip:
				'''
				Включает/Выключает тему 4 интерлюдий.
				Эти интерлюдия проигрываются после победы над Экзо-механизмами и Серной ведьмой вместо «Their Fabricator» и «Acceptance».
				'''
		}

		AdjustAdvisorSpawnConditions: {
			Label: Изменение условий призыва Аналитика
			Tooltip:
				'''
				Меняет условия для призыва Аналитика так, чтобы возможность его призвать была доступна не постоянно
				Особенно полезно, если вы играете с Infernum, так как в ином случае его шкала здоровья будет отображаться всегда, поскольку Аналитик всегда жив.
				Может вызывать проблемы при игре в мультиплеере, поэтому советуем отключать эту опцию, когда вы играете в мультиплеере.
				'''
		}

		MultiplayerBossRespawnTimer: {
			Label: Время возрождения в мультиплеере
			Tooltip: Сколько будет длиться возрождение во время битв с боссами.
		}

		MinimumDifficultyToPreventRespawns: {
			Label: Минимальная сложность для отключения возрождений
			Tooltip: Минимальная сложность для включения системы предотвращения возрождений.
		}

		MultiplayerRespawnsAllowed: {
			Label: Количество возможных возрождений
			Tooltip: Количество возможных возрождений во время битв с боссами.
		}

		NerfThoriumMulticlass: {
			Label: Ослабление мультикласса Thorium
			Tooltip: Добавляет систему для ослабления мультикласса в виде предотвращения использования барда и целителя при игре за мультикласс.
		}

		ColoredRelics: {
			Label: Цветные реликвии
			Tooltip: Включает/Выключает окрашивание реликвий из этого мода.
		}

		ForceMenu: {
			Label: Всегда использовать главное меню мода
			Tooltip: При загрузке игры принудительно переключает тему меню на «Infernal Eclipse of Ragnarok».
		}

		AutomatedConfigSetup: {
			Label: Автоматическая предустановка конфигураций других модов
			Tooltip: Автоматически меняет некоторые конфигурации на заданные в разных модах для наилучшего игрового опыта с модпаком Infernal Eclipse of Ragnarok.
		}

		MoveDeerclopsChecklistEntry: {
			Label: Передвинуть Циклопа-оленя в журнале боссов
			Tooltip: Сдвигает Циклопа-оленя в журнале боссов на одну позицию вверх для лучшего соответствия с балансом Calamity и Infernum.
		}

		DontEnableThis: {
			Label: Не включайте это
			Tooltip: Просто не надо. Скорее всего, включение этой настройки даст вам неверное представление об игре и приведёт к крайне несбалансированному и нестабильному игровому опыту.
		}

		CalamityExpertAccessories: {
			Label: Аксессуары режима Эксперта из Calamity
			Tooltip: Некоторые аксессуары с боссов Calamity можно будет получить только в режиме Эксперт и выше.
		}

		ThereIsNoReasonDisableThis: {
			Label: Не отключайте это
			Tooltip:
				'''
				Просто не надо, эта настройка отключает все плохо работающие в совмещении с режимом Инфернум сложности.
				Отключайте только в случае, если вы действительно знаете, что делаете, а также не сообщайте нам о каких-либо игровых ошибках после отключения этой настройки.
				'''
		}

		DeveloperMode: {
			Label: Режим разработчика
			Tooltip: Включает/Выключает возможность использования полезных для разработчиков инструментов.
		}

		ForceRagnarokInfernumModeInSubworlds: {
			Label: Автоматические включение Рагнарёка или Инфернума в подмирах
			Tooltip:
				'''
				Автоматически включает либо режим Инфернум либо Рагнарёк в зависимости от выставленной ванильной сложности мира.
				Эксперт включает Инфернум, а Мастер включает Рагнарёк.
				'''
		}

		BereftVassalRagnarok: {
			Label: Рагнарёк-тема Обездоленного вассала
			Tooltip: Включает/Выключает проигрывание трека «Dead Kingdom's Champion» за авторством Techhy plays во время битвы с Обездоленным вассалом в режиме Рагнарёк.
		}

		DoGRagnarok: {
			Label: Рагнарёк-тема финальной фазы Пожирателя богов
			Tooltip: Включает/Выключает проигрывание трека «Last Battle (Ballos Mix)» за авторством DM DOKURO во время финальной фазы и фазы отчаяния Пожирателя богов в режиме Рагнарёк.
		}

		WarMachineBossInBossRush: {
			Label: Вульфрумовый корабль-носитель в Босс-раше
			Tooltip: Добавляет Вульфрумовый корабль-носитель в Босс-раш.
		}

