				'''
				Добавляет дополнительную характеристику к [i:3991][c/8fd71d:чародейскому цветку].
				[c/b25140:Стоит отметить, что] [c/ff872b:Calamity Mod] [c/b25140:уже добавляет] [i:3991][c/8fd71d:чародейскому цветку] [c/b25140:увеличение магического урона на 5%.]
				[c/828282:Значение по умолчанию: Критический удар]
				'''
		}

		MagicCuffsChange: {
			Label: "[i:1595] Изменение магических наручников"
			Tooltip:
				'''
				[i:1595][c/9696ff:Магические наручники] и [i:2221][c/00f2fa:неземные наручники] теряют свою способность давать ману при получении урона.
				Вместо этого они получат характеристики [i:982][c/d2a0ff:браслета восстановления маны] и будут увеличивать защиту на 2 единицы.
				[c/828282:Значение по умолчанию: Вкл]
				'''
		}

		AltOreGemStaffRecipes: {
			Label: "[i:706] Возможность создания самоцветных посохов из альт. руды"
			Tooltip:
				'''
				Добавляет новые рецепты создания самоцветных посохов, позволяя создавать их при помощи альтернативного варианта руды, из которой они обычно создаются.
				Например, эта настройка позволяет получить [i:744][c/b5c2d9:алмазный посох] в мире, где вместо нужной вам [i:702][c/b5c2d9:платины] сгенерировалось [i:13][c/e5d67f:золото].
				[c/828282:(Пример:] [i/s10:20][c/828282:+][i/s8:180][c/828282:@][i:35] [c/828282:->] [i:740][c/828282:)]
				[c/828282:Значение по умолчанию: Вкл]
				'''
		}

		WandOfSparkingRecipe: {
			Label: "[i:8] Возможность создания палочки для розжига"
			Tooltip:
				'''
				Добавляет рецепт создания палочке для розжига, упрощая способ её получения.
				[i/s99:8][c/828282:+][i:75][c/828282:@][i:35] [c/828282:->] [i:3069]
				[c/828282:Значение по умолчанию: Вкл]
				'''
		}

		EvilOrbMageWeaponSwapRecipes: {
			Label: "[i:115] Возможность обмена мерзкой колючки и багряного жезла между собой"
			Tooltip:
				'''
				Добавляет рецепты создания, позволяющие обменять мерзкую колючку на багряный жезл или наоборот.
				Также добавляет такую же возможность обменивать оба предмета между собой при трансмутации одного из них в мерцании.
				[i:1256][c/828282:+][i/s8:1257][c/828282:@] [c/ff6666:Багряный алтарь] [c/828282:->] [i:64]
				[i:64][c/828282:+][i/s8:57][c/828282:@] [c/797197:Демонический алтарь] [c/828282:->] [i:1256]
				[c/828282:Значение по умолчанию: Вкл]
				'''
		}
