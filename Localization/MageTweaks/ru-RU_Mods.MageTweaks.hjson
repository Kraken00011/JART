		StarDespawnTime: {
			Label: "[i:709] Длительность существования звёзд маны"
			Tooltip:
				'''
				Определяет длительность существования [i:184][c/5559ff:звёзд маны].
				После истечения этого времени звезда автоматически пропадёт.
				Если значение будет выставлено на 0, [i:184][c/5559ff:звёзды маны] не будут пропадать.
				[c/828282:Значение по умолчанию: 30]
				'''
		}

		NoWastedStars: {
			Label: "[i:109] Сниженное использование звёзд маны"
			Tooltip:
				'''
				Даёт возможность подбирать [i:184][c/5559ff:звёзды маны] только, если у вас недостаёт более чем 20 ед. маны
				Особенно полезно при игре в мультиплеере и во время прохождения событий
				[c/828282:Значение по умолчанию: Вкл]
				'''
		}

		ManaPotionStatChange: {
			Label: "[i:189] Ослабление зелий маны"
			Tooltip:
				'''
				Определяет силу ослаблений для [i:189][c/3d66ff:зелий маны].
				[c/828282:Значение по умолчанию: Среднее]
				'''
		}

		ReworkedManaFlowerCooldown: {
			Label: "[i:17] Перезарядка цветка маны"
			Tooltip:
				'''
				Устанавливает количество секунд, нужных для перезарядки новой характеристики, включаемой настройкой [c/e7c725:«Переработка цветка маны»] для [i:555][c/8fd71d:цветка маны]
				[c/828282:Значение по умолчанию: 8]
				'''
		}

		ManaFlowerRework: {
			Label: "[i:555] Переработка цветка маны"
			Tooltip:
				'''
				Так как возможность [i:555][c/8fd71d:цветка маны] автоматически использовать [i:189][c/3d66ff:зелья маны] теперь доступна постоянно,
				у него появится новая характеристика - создание [i:MageTweaks/FloweringManaStar][c/5559ff:звезды маны] при попадании по врагу раз в определённое количество секунд.
				[c/828282:Значение по умолчанию: On]
				'''
		}

		MagicPotionChange: {
			Label: "[i:293] Изменение магических зелий"
			Tooltip:
				'''
				При включении [i:293][c/f6229f:зелье регенерации маны] перестанет работать.
				Вместо этого [i:294][c/a35fff:зелье магической силы] начнёт давать ослабленную версию того же баффа.
				В отличии от своей прошлой версии, когда игрок перестаёт двигаться,
				его скорость восстановления маны увеличится как обычно, независимо от того, наложен на вас этот бафф или нет.
				[c/828282:Значение по умолчанию: Вкл]
				'''
		}

		MagicPowerPotionDuration: {
			Label: "[i:294] Время действия зелья магической силы"
			Tooltip:
				'''
				Устанавливает длительность баффа от [i:294][c/a35fff:зелья магической силы], в минутах.
				[c/828282:Значение по умолчанию: 8]
				'''
		}

		ExtraCelestialMagnetSource: {
