Configs: {
	FancyWhipsConfig: {
		DisplayName: Конфигурация

		DefaultHitboxes: {
			Label: Использование ванильных хитбоксов
			Tooltip:
				'''
				Включает/Выключает модифицирование хитбоксов хлыстов.
				Если включено: Хлысты будут использовать ванильные хитбоксы.
				Если выключено: Хлысты будут использовать улучшенные хитбоксы, куда лучше подходящие новой анимации.
				'''
		}
	}
}
