UI: {
	TreePassivesHeader: Tree Passives
	NoNodeSelected: No passives allocated
	AvailablePoints: ДОСТУПНО ОЧКОВ: {0}
	Level: УРОВЕНЬ: {0} / {1}
	EXP: ОП: {0} / {1} ({2}%)
	MaxLevel: МАКСИМАЛЬНЫЙ УРОВЕНЬ ДОСТИГНУТ
	FallenLeaf: Right-Click to refund a node
	ShiftingLeaf: Shift + Right-Click to reroll a node
	ShiftingLeaf2: A rerolled node cannot be rerolled again until Moon Lord is defeated
	HUDLocked: Locked
	HUDUnlocked: Unlocked
}

Keybinds: {
	"Open Item Passive Tree.DisplayName": Open  Item  Passive  Tree
	"Zoom Out .DisplayName": Zoom  Out
}

Stats: {
	# Generic formatters
	StatFormat: "{0} {1}"
	BuffFormat: holding or Equipping this item grants {0}
	MinionBuffFormat: holding or Summoning minions with this item grants {0}
	ImbueTutorialFormat:
		'''
		Only one imbue node can be allocated at a time
		Allocating this node transforms other imbue nodes into random nodes
		Refunding this node restores transformed imbues
		'''
	# Stat Names
	Damage: Damage
	AttackSpeed: attack speed
	CritChance: critical strike chance
	Knockback: knockback
	ArmorPenetration: armor penetration
	TagDamage: summon tag damage
	LifeMax: max life
	MovementSpeed: movement speed
	Defense: defense
	Luck: luck
	PlacementRange: placement range
	GrabRange: grab range
	ClickerRadius: click radius
	# Short labels for the Hexagon Nodes
	ProjectileSize: projectile size
	ProjectileVelocity: projectile velocity
	ProjectileCount: aditional projectile
	ProjectilePenetrate: projectile penetration
	LifeSteal: chance to life steal
	MinionCount: minion
	SentryCount: sentry
	WhipRange: whip range
	ManaCost: mana cost
	ManaRegen: mana regen
	ManaMax: max mana
	AmmoConsumption: chance to save ammo
	ToolSpeed: tool speed
	ToolRange: tool range
	PickaxePower: mining speed
	FishingPower: fishing power
	WeaponSize: weapon size
	# Imbues / Buffs
	MinionImbueFire: Minion Imbue: Fire
	MinionImbuePoison: Minion Imbue: Poison
	MinionImbueShadow: Minion Imbue: Shadow
	MinionImbueVenom: Minion Imbue: Venom
