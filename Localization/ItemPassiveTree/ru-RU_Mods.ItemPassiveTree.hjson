Tooltips: {
	TreeTutorial: Press '[c/FFFFFF:{0}]' to view passive tree
	KeyNotBoundWarning: (!) No key assigned! Go to Settings -> Controls to set a key
	HoldShift: Hold [c/AAAAAA:Shift] to view tree passives
	TreeNodesTitle: Tree Passives:
	NoKeyBound: NONE
}

Items: {
	AcornofTransmutation: {
		DisplayName: Acorn of Transmutation
		Tooltip:
			'''
			Refunds and regenerates a completely new passive tree on the item used
			Hold this item and right-click an item with a passive tree to use it
			'''
		Replant: "{0}'s roots have been replanted!"
	}

	EssenceofAutumn: {
		DisplayName: Essence of Autumn
		Tooltip:
			'''
			Refunds all allocated points on the item passive tree
			Hold this item and right-click an item with a passive tree to use it
			'''
		Refund: Passive points have been refunded for {0}.
	}

	FallenLeaf: {
		DisplayName: Fallen Leaf
		Tooltip: Grants a passive refund point
	}

	ShiftingLeaf: {
		DisplayName: Shifting Leaf
		Tooltip: Grand a node reroll point
	}

	LeechItem: {
		DisplayName: Leech
		Tooltip: ""
		NoEXP:
			'''
			Attaching this Leech to an item will siphon the EXP it gains and store it
			[c/32FF82:Stored: {0:N0} / {1:N0} EXP]
			The Leech can be detached at any time
			Once the Leech has stored EXP, it becomes nourished when detached
			Nourished Leechs can be used on items to transfer their stored EXP
			[c/808080:Hold this Leech and right-click an item with a passive tree to attach it]
			'''
		WithEXP:
			'''
			[c/32FF82:Stored: {0:N0} / {1:N0} EXP]
			The Leech is consumed after transferring the EXP
			[c/808080:Hold this Leech and right-click an item with a passive tree to transfer the stored EXP]
			'''
		HostStatus: "{0} Stored EXP: {1:N0} / {2:N0}"
		HostInstruction: (Shift + Right-Click to detach {0})
		Extract: The {0:N0} has been detach!
		Absorb: The {0:N0} absorbs {1} stored EXP!
		Siphon: The {0:N0} is now being siphoned by a {1}!
	}

	FungalLeech: {
		DisplayName: Fungal Leech
		Tooltip: ""
	}

	SporelingLeech: {
		Tooltip: ""
		DisplayName: Sporeling Leech
	}

	MutantLeech: {
		Tooltip: ""
		DisplayName: Mutant Leech
	}

	SpectralLeech: {
		Tooltip: ""
		DisplayName: Spectral Leech
	}

	HeartoftheForest: {
		DisplayName: Heart of the Forest
		Tooltip:
			'''
			20% of experience gained is shared with items that have a passive tree
			Increases maximum life by 20
			'''
	}

	OvergrownHeartoftheForest: {
		DisplayName: Overgrown Heart of the Forest
		Tooltip:
			'''
			50% of experience gained is shared with items that have a passive tree
			Increases maximum life by 40
			'''
	}

	ExtractorItem: {
		UsedPrefix: "[Used] {0}"
		FilledPrefix: "[Filled] {0}"
		EmptyTooltip:
			'''
			[c/32FF82:Stored: {0:N0} / {1:N0} EXP]
			Can extract EXP from an item and transfer it to other items
			Once any EXP is transferred, the extractor becomes [Used] and can no longer extract EXP
			If no EXP remains in a [Used] extractor, it will break
			'''
		FullTooltip: "[c/32FF82:Stored: {0:N0} / {1:N0} EXP]"
		TransferRules:
			'''
			Can extract EXP from an item and transfer it to other items
			Once any EXP is transferred, the extractor becomes [Used] and can no longer extract EXP
			If no EXP remains in a [Used] extractor, it will break
			'''
		UsedInfo: Can transfer the stored EXP to other items
		UsedWarning: This extractor has been used to transfer EXP and can no longer extract
		BreakWarning: Transferring the remaining EXP will break this extractor!
		InstructionGive: Hold this Extractor and Shift + Right-click an item to transfer EXP
		InstructionGeneral: Hold this Extractor and Right-click an item to extract EXP / Shift + Right-click to transfer EXP
	}

	SapExtractor: {
		Tooltip: ""
		DisplayName: Sap Extractor
	}

	HallowedSapExtractor: {
		DisplayName: Hallowed Sap Extractor
		Tooltip: ""
	}

	CelestialSapExtractor: {
		Tooltip: ""
		DisplayName: Celestial Sap Extractor
	}
}
