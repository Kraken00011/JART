Configs: {
	Config: {
		DisplayName: Конфигурация

		Headers: {
			HeaderWeapons: Модификации оружия
			HeaderBoss: Модификации боссов
		}

		bossHealthMultiplier: {
			Label: Множитель здоровья Ядра
			Tooltip:
				'''
				Увеличивает здоровье Ядра Искажения и Багрянца под заданный множитель
				Также влияет на здоровье Орбиталов, но не на Теневых духов
				Используйте, если босс кажется для вас слишком лёгким/сложным
				'''
		}

		wispHealthMultiplier: {
			Label: Множитель здоровья духов
			Tooltip:
				'''
				Увеличивает здоровье Теневых духов под заданный множитель
				Используйте, если босс или его миньоны кажутся для вас слишком лёгкими/сложными
				'''
		}

		bossDefenseMultiplier: {
			Label: Множитель защиты Ядра
			Tooltip:
				'''
				Увеличивает защиту Ядра Искажения и Багрянца под заданный множитель
				Также влияет на защиту Орбиталов и Теневых духов
				Используйте, если босс кажется для вас слишком лёгким/сложным
				'''
		}

		bossDamageMultiplier: {
			Label: Множитель урона Ядра
			Tooltip:
				'''
				Увеличивает урон Ядра Искажения и Багрянца под заданный множитель
				Также влияет на урон Орбиталов и Теневых духов, как и на урон их снарядов соответственно
				Используйте, если босс кажется для вас слишком лёгким/сложным
				'''
		}

		attackVelocityMultiplier: {
			Label: Множитель скорости атаки Ядра
			Tooltip:
				'''
				Увеличивает скорость большинства атак Ядра Искажения и Багрянца под заданный множитель
				Также влияет на скорость атаки Орбиталов и Теневых духов
				В добавок, меняет скорость вращения Теневых духов и Бомб ночи
				Используйте, если босс кажется для вас слишком лёгким/сложным
				'''
		}

		bossSpeedMultiplier: {
			Label: Множитель скорости Ядра
			Tooltip:
				'''
				Увеличивает скорость передвижения Ядра Искажения и Багрянца под заданный множитель
				Также меняет и инерцию, которая определяет насколько быстро/резко Ядро может менять направления движения
				Используйте если босс кажется для вас слишком лёгким/сложным
				Влияет только на битву с Ядром Искажения/Багрянца; Ничего не делает, если включена опция «{$Mods.CorruptionBoss.Configs.Config.legacyMode.Label}»!
				'''
		}

		rangedWepDmgMultiplier: {
			Label: Множитель урона дальнобойного оружия
			Tooltip:
				'''
				Увеличивает урон Проклятого карабина и Багровой железки под заданный множитель
				Не влияет на другое оружие, добавляемое модом
				Кража жизни Багровой железки будет усиливаться непропорционально множителю
				Может сбалансировать силу оружий под ваши нужды
				'''
		}

		meleeWepDmgMultiplier: {
			Label: Множитель урона оружия ближнего боя
			Tooltip:
				'''
				Увеличивает урон Ядра горечи и Кровавого гуанадо под заданный множитель
				Не влияет на другое оружие, добавляемое модом
				Может сбалансировать силу оружий под ваши нужды
				'''
		}

		magicWepDmgMultiplier: {
			Label: Множитель урона магического оружия
			Tooltip:
				'''
				Увеличивает урон Осквернённой иглы и Кровожадности под заданный множитель
				Не влияет на другое оружие, добавляемое модом
				Не влияет на регенерацию от Кровожадности
				Может сбалансировать силу оружий под ваши нужды
				'''
		}

		summonWepDmgMultiplier: {
			Label: Множитель урона оружия призывателя
			Tooltip:
				'''
				Увеличивает урон Орбитального посоха и Порченного взмаха под заданный множитель
				Не влияет на другое оружие, добавляемое модом
				Не влияет на метку шанса критического удара Порченного взмаха
				Миньоны Орбитального посоха должны быть призваны заново для изменения множителя
				Может сбалансировать силу оружий под ваши нужды
				Оружия призывателя склонны сильнее изменять свой урон от множителей, так что лучше ставьте этот множитель ниже остальных
				'''
		}
	
		forcedAI: {
			Label: Сложность ИИ
			Tooltip:
				'''
				Позволяет вам менять уровень сложности ИИ Ядра теней. На выбор у вас есть:
				- Default (Обычная): ИИ будет базироваться на сложности мира
				- Classic (Классика): Будет использоваться ИИ Классической сложности
				- Expert (Эксперт): Будет использоваться ИИ Экспертной сложности
				- EX: На голову сильнее экспертного ИИ с усиленными атаками, в обычных ситуациях не используется
				Ничего не делает, если включена опция «{$Mods.CorruptionBoss.Configs.Config.legacyMode.Label}»!
				'''
		}

		legacyMode: {
			Label: Классический режим
			Tooltip:
				'''
				Заменяет Ядро теней своей предыдущей версией - Ядром Искажения или Багрянца
				Также Подозрительно выглядящие сферы будут призывать Ядро Искажения сразу же после их уничтожения
				'''
		}

		orbResistedProjs: {
			Label: Ослабленные снаряды
			Tooltip:
				'''
				Снаряды из этого списка будут наносить в 2 раза меньше урона по орбиталам
				Данная опция нужна, чтобы сделать орбиталов менее уязвимыми во время битв
				Работает только во время битвы с Ядром тьмы; не влияет на игру, если включена опция «{$Mods.CorruptionBoss.Configs.Config.legacyMode.Label}»!
				'''
		}
    }
}

