			'''
	}

	CrystallineUmbra: {
		DisplayName: Кристаллизованная тьма
		Tooltip:
			'''
			Увеличивает шанс критического удара на 10%
			Сокращает задержку для начала регенерации маны
			Враги будут реже выбирать вас в качестве цели
			Даёт критическим ударам 50% шанс потратить ману на вызов мощного взрыва, наносящего дополнительный урон
			Количество используемой маны зависит от эффектов снижения расхода маны, урона оружия и его шанса критического удара
			'Они даже не поймут, что происходит'
			'''
	}

	ShatteredShell: {
		DisplayName: Разбитая оболочка
		Tooltip:
			'''
			Даёт невосприимчивость к отбрасыванию
			Отражает вражеский урон
			При получении урона разбрасывает множество взрывных осколков в разные стороны
			'Это, конечно, не остановит их, но определённо заставит поплатиться за то, что посмели атаковать вас'
			'''
	}

	ShatterspikeBracer: {
		DisplayName: Оскольчатый браслет
		Tooltip:
			'''
			Даёт невосприимчивость к отбрасыванию
			Отражает вражеский урон
