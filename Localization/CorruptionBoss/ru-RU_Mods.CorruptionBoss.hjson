	}

	ShadowRing: {
		DisplayName: Теневое кольцо
		Tooltip:
			'''
			Призывает 3 искажённых орбитала на вашу защиту
			Орбиталы могут наносить контактный урон и получать его от врагов и их снарядов
			При получении достаточного количества урона орбитал будет временно разбит
