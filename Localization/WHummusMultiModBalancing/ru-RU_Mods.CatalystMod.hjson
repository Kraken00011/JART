Items: {
	CoralCrusher: {
		DisplayName: Коралловый крушитель
		Tooltip:
			'''
			4% урона от метки призывателя
			{$Mods.CatalystMod.Tooltips.WhipTooltip}
			При попадании кончиком хлыста во врага вонзает коралловый осколок
            Атаки миньонов могут разбить коралловый осколок, останавливая движение врага и нанося 6% урона от метки призывателя
			'''
	}

	ResonantStriker: {
		DisplayName: Резонансный ударник
		Tooltip:
			'''
			8% урона от метки призывателя
			{$Mods.CatalystMod.Tooltips.WhipTooltip}
			Выпускает самонаводящиеся электрические сферы при попадании во врага
            Ваши миньоны оглушают врагов при попадании (не работает на боссах)
			'''
	}

	BlossomsBlessing: {
		DisplayName: Благословение цветения
		Tooltip:
			'''
			12% урона от метки призывателя
			{$Mods.CatalystMod.Tooltips.WhipTooltip}
			Разносит лепестки по ветру
            Прикоснитесь к самому большому лепестку, чтобы получить благословение регенерации, урона и шипов
            'Он цветёт: мой алый цветок, растёт, цветёт, слабеет и сохнет росток'
			'''
	}

	UnrelentingTorment: {
		DisplayName: Неумолимая тоска
		Tooltip:
			'''
			10% урона от метки призывателя
			{$Mods.CatalystMod.Tooltips.WhipTooltip}
			Выпускает каскад потусторонних когтей, разрывающих врагов
			'''
	}

	Catharsis: {
		DisplayName: Катарсис
		Tooltip:
			'''
			12% урона от метки призывателя
			{$Mods.CatalystMod.Tooltips.WhipTooltip}
			Взмахи хлыстом совершаются ценой собственного здоровья
            При попадании по врагам накапливается заряд крови. Можно накопить до 20 зарядов
            Нажмите ПКМ, чтобы активировать заряды, временно усиливая Катарсис и восстанавливая потерянное здоровье
            [c/c61b40:Очищающий свет, покинутый и поглощённый болью,]
            [c/c61b40:Вернулся в этот мир всепоглощающей тенью]
			'''
	}
}

ArmorSetBonus.IntergelacticRanged:
	'''
	Стрелковое оружие призывает звёзды, наносящие 10% урона
    Даёт невосприимчивость к дебаффу [cbuff:CatalystMod/AstralBlight], а ваши атаки накладывают его
	'''