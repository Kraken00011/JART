Configs: {
	WHummusConfigs: {
		DisplayName: Конфигурация WHummus

		ThoriumBossesReworkedBossScalingMessage: {
			Label: Сообщение о масштабировании боссов из-за Thorium Helheim
			Tooltip: Включает/Выключает вывод в чат специфического предупреждающего сообщения, отображающегося при заходе в мир.
		}

		RadiantMultiClassNerf: {
			Label: Ослабление целителя при игре за мультикласс
			Tooltip: Снижает урон и бонусное исцеление при использовании оружия другого класса на 10 секунд.
		}

		MultiModShieldMerges: {
			Label: Объединение щитов между модами
			Tooltip: Объединяет эффекты щитов из разных поддерживаемых модов.
		}

		MultiModToothMerges: {
			Label: Объединение ожерелий из акульих зубов между модами
			Tooltip: Объединяет связанные ожерельями из акульих зубов аксессуары из разных поддерживаемых модов.
		}

		MultiModFlowerMerges: {
			Label: Объединение цветков маны между модами
			Tooltip: Объединяет связанные цветками маны аксессуары из разных поддерживаемых модов.
		}

		ThrowerRogueMerge: {
			Label: Объединение метателя с разбойником
			Tooltip: Полностью объединяет метателя и разбойника в 1 класс, исправляет перековки и бонус к урону от скрытных ударов.
		}

		MultiModRogueMerges: {
			Label: Объединение аксессуаров разбойника
			Tooltip: Объединяет разбойные аксессуары из разных поддерживаемых модов.
		}

		MultiModSummonerMerges: {
			Label: Объединение аксессуаров призывателя
			Tooltip: Объединяет аксессуары призывателя из разных поддерживаемых модов.
		}

		MultiModTunerMerges: {
			Label: Объединение тюнеров
			Tooltip: Объединяет связанные тюнерами аксессуары и сами тюнеры из разных поддерживаемых модов.
		}

		MultiModHealerMerges: {
			Label: Объединение аксессуаров целителя
			Tooltip: Объединяет аксессуары целителя из разных поддерживаемых модов.
		}

		MultiModQuiverMerges: {
			Label: Объединить колчаны
			Tooltip: Объединяет колчаны из разных поддерживаемых модов.
		}

		MultiModMeleeMerges: {
			Label: Объединить аксессуары воина
			Tooltip: Объединяет рукавицы ближнего боя из разных поддерживаемых модов.
		}

		RagnarokWarningMessage: {
			Label: Сообщение о конфликтующей балансировке Ragnarok
			Tooltip: Включает/Выключает вывод в чат специфического предупреждающего сообщения, отображающегося при заходе в мир.
		}

		MultiModShoeMerges: {
			Label: Объединить ботинки из разных модов
			Tooltip: Объединяет связанные с ботинками аксессуары из разных поддерживаемых модов.
		}

		BardMultiClassNerf: {
			Label: Ослабление барда при игре за мультикласс
			Tooltip: Removes bard empowerments from the player who granted them if that player uses a non-bard weapon.
		}

		DuplicateArmorEctoMist: {
			Label: Дубликаты брони через экто-туман
			Tooltip: Выставляет приоритет шлемам из Unofficial Calamity Bard & Healer, версии из Ragnarok всё ещё можно получить через экто-туман.
		}
	}
}

