ItemDescriptions: {
	GrenadeLauncher:
		'''
		Удерживайте ПКМ, чтобы ускорить детонацию мин
		Отпустите, чтобы мгновенно взорвать все выпущенные заряды
		'''

	RocketLauncher:
		'''
		Нажмите ПКМ, чтобы пометить ближайшего к вашему курсору врага
		Ракеты самонаводятся на помеченную цель
		'''

	NettleBurst:
		'''
		Нажмите ЛКМ, чтобы выстрелить колючками
		Нажмите ПКМ, чтобы выстрелить пучком семян, расцветающих при попадании
		Попадание колючками по цветенью заставит его разорваться
		Ближайшие колючки рвутся во время детонации цветка
		Когда цветок взрывается, ближайшие к нему цветки также начнут взрываться
		После взрыва даёт временное усиление для нескольких следующих атак
		'''
		
	ChlorophyteBullet:
		'''
		Пробивает несколько целей за раз и может отскакивать от стен
		Отскакивает в сторону врага, если таковой есть поблизости
		'''
		
	ChlorophyteClaymore:
		'''
		, отскакивающей от стен
		Удерживайте ЛКМ, чтобы зарядить клеймор, после, отпустите для выстрела мощной заряженной атакой
		Заряженные атаки вызывают мощные ударные волны, отскакивающие от поверхностей
		Нажмите ПКМ, чтобы атаковать как обычно
		'''
		
	ChlorophyteSaber: При попадании по врагу создаёт облако спор
	
	ChlorophytePartisan:
		'''
		Атаки выпускают неподвижные листья, привязанные к игроку
		Каждая 3 атака проталкивает протазан вперёд, выпуская листья и давая им самонаводку
		'''

	GolemEye: Каждый пятый удар гарантировано будет критическим
	
	Stynger:
		'''
		Имеет магазин на 5 болтов
		Когда магазин опустеет, Стингер уйдёт на перезарядку
		Нажмите ПКМ с полным магазином, чтобы выстрелить всеми болтами одновременно
		'''
		
	HeatRay:
		'''
		Через некоторое время после начала атаки луч начнёт перегреваться, увеличивая свой урон
		Перегретый луч поджигает и снижает вражескую броню
		Стреляя в подожжённых врагов, есть шанс взорвать их
		'''
		
	NanoBullet: Накладывает дебафф «Замешательство» и самонаводится на врагов

	PulseBow:
		'''
		Нажмите ЛКМ, чтобы сделать обычный выстрел
		Удерживайте ЛКМ, чтобы зарядить лук и увеличить мощность выстрела
		Полностью заряженные атаки выпускают пульсирующие болты вместо обычных стрел
		Каждые 3 последовательных заряженных выстрела будут усиливать следующие 2 атаки, заменяя болты на пульсирующие лучи
		После отстрела всех усиленных атак заряд лука будет временно замедлен
		При ношении полного комплекта Грибнитовой брони вы сможете оставаться в невидимости даже во время атаки луком
		'''

	LaserMachineGun: При достижении максимальной скорострельности создаёт щит, увеличивающий сопротивление урону до 25%
	
	ButchersChainsaw:
		'''
		При постоянном нанесении урона позволяет задерживаться в воздухе
		Нажмите ПКМ, чтобы бросить бензопилу, ненадолго застревающую во враге, нанося ему постепенный урон
		Одновременно можно бросить только 2 бензопилы
		'''

	ShinyStone: {
		Tooltip:
			'''
			Немного увеличивает защиту соразмерно недостающему здоровью
			Сокращает время, нужное для достижения максимальной регенерации здоровья
			Значительно сокращает время, нужное для начала регенерации маны
			'''
		TooltipFlavor: "'Станьте хранителем'"
		TooltipThoriumMod: Увеличивает лучезарный урон, скорость произнесения заклинаний и шанс критического удара на 10%
		TooltipGeneral: Даёт эффекты от предмета «Сияющий камень»
	}
}

Buffs: {
	GolemMount: {
		DisplayName: Яхщеровый мех
		Description:
			'''
			Значительно увеличивает защиту
			'Яхщер в бронированном костюме. А снять, кто ты без него?'
			'''
	}
}

Items: {
	CursedTotem: {
		DisplayName: Проклятый тотем
		Tooltip:
			'''
			Призывает одержимые яхщеровые статуи
			Статуи не могут находиться на платформах
			'''
	}

	GraspofGrass: {
		DisplayName: Природные объятия
		Tooltip:
			'''
			Стреляет семенами в комбо из шести выстрелов
			Первые 2 выстрела запускают ядовитые семена с большим уроном, но с большой задержкой между выстрелами
			Следующие 3 выстрела запускают отравляющие семена со сниженным уроном, но с минимальной задержкой
			Последний выстрел запускает колючий шар, пробивающий множество целей
			При ношении в руках призывает фею, наносящую урон призывателя и усиливающуюся от его бонусов
			Фея атакует только отмеченных меткой призывателя врагов
			Попадание по врагам семенами также оставляет на них невидимые метки призывателя
			Использует семена [i/s1:Seed] в качестве боеприпасов
			'Потрогай травки'
			'''
	}

	LihzahrdKey: {
		DisplayName: Яхщеровый меха-ключ
		Tooltip:
			'''
			Позволяет использовать тело Голема как собственное оружие
			'Почувствуйте себя в шкуре собственного врага!'
			'''
	}

	ScorchedEarth: {
		DisplayName: Выжегатель земель
		Tooltip:
			'''
			Нажмите ЛКМ, чтобы запустить высокоскоростные стрелы, накладывающие дебафф «В огне!»
			Удерживайте ЛКМ, чтобы зарядить лук
			При полной зарядке выстреливает 3 замедленными стрелами, самонаводящимися на врагов и вызывающими взрыв при попадании
			'''
	}

	Sunbracers: {
		DisplayName: Солнцестояние
		Tooltip:
			'''
			Конвертирует ракеты в маленькие солнца, способные некоторое время задерживаться на поверхности
			Пока находится на поверхности, мини-солнце периодически испускает плазму, поджигающую врагов
			'Кто-то, по сей видимости, решил собрать себе мини-крематорий'
			'''
	}

	TempleLink: {
		DisplayName: Храмовая связь
		Tooltip:
			'''
			Телепортирует использовавшего к алтарю яхщеров
			'А вы знали, что яхщеры использовали лавовые лампы?'
			'''
	}
}

