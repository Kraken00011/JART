Configs: {
	ReworkConfig: {
		DisplayName: Конфигурация

		plantera: {
			Label: "[i/s1:2109] Переработка Плантеры"
			Tooltip:
				'''
				Включает переработку Плантеры, выключите. Если переработка конфликтует с другими модами.
				Работает в режимах Вечности и Мести, так что вам не нужно выключать настройку, если один из них включён.
				(ПРИМЕЧАНИЕ: Паттерны атак комбинируются, не заменяются!)
				'''
		}

		golem: {
			Label: "[i/s1:2110] Переработка Голема"
			Tooltip:
				'''
				Включает переработку Голема. Выключите, если переработка конфликтует с другими модами.
				Работает в режимах Вечности и Мести, так что вам не нужно выключать настройку, если один из них включён.
				(ПРИМЕЧАНИЕ: Паттерны атак комбинируются, не заменяются!)
				'''
		}

		temple: {
			Label: "[i/s1:1292] Изменение комнаты алтаря Голема"
			Tooltip: Немного меняет генерацию комнаты алтаря Голема.
		}

		lihzahrd: {
			Label: "[i/s1:1154] Переработка ИИ яхщеров (Требуется перезагрузка!)"
			Tooltip: Включает переработанный ИИ для яхщеров.
		}

		skipPlantDesperation: {
			Label: "[i/s1:2109] Пропускать фазу отчаяния Плантеры после первой победы над ней"
			Tooltip: Пропускает последнюю фазу Плантеры, если она была хотя бы один раз убита в мире.
		}

		masterDropsAreNonExclusive: {
			Label: Оружие Мастера становится Экспертным
			Tooltip:
				'''
				Эксклюзивное для режима Мастер оружие после включения опции будет выпадать и на сложности Эксперт.
				Рекомендуется, если вам не нравится режим Мастер или другие моды мешают в него играть.
				(Например режим Вечность на Мастере становится Мазохистом, а Инфернум не позволяет играть на Мастере вообще)
				'''
		}

		laser: {
			Label: "[i/s1:1266][i/s1:1295][i/s1:1444][i/s1:2749] Улучшение эффектов старых лазеров (Требуется перезагрузка!)"
			Tooltip: Заменяет старые эффекты лазерных снарядов на новые.
		}

		bullet: {
			Label: "[i/s1:1179][i/s1:1350] Перебалансировка хлорофитовых и нано-пуль"
			Tooltip:
				'''
				Меняет местами функционал нано и хлорофитовых пуль между собой, параллельно немного улучшая их.
				Хлорофитовые пули теперь отскакивают от стен и пробивают несколько врагов за раз.
				Нано-пули самонаводятся на ближайшего к вашему курсору врага, а также, если возможно, будут облетать поверхность.
				'''
		}

		golemEye: {
			Label: "[i/s1:1248] Переработка глаза Голема"
			Tooltip: При экипировке каждая 5 атака гарантированно будет критической.
		}

		GL: {
			Label: "[i/s1:758] Переработка гранатомёта"
			Tooltip: Перерабатывает анимацию атаки и даёт возможность моментально взорвать выпущенные заряды.
		}

		RL: {
			Label: "[i/s1:759] Переработка ракетомёта"
			Tooltip: Перерабатывает анимацию атаки Ракетомёта и даёт возможность помечать врагов для последующего наведения на них.
		}

		nettleBurst: {
			Label: "[i/s1:788] Переработка крапивного взрыва"
			Tooltip: Даёт предмету альтернативную атаку на ПКМ, стреляющую семенами цветков, которые присасываются к врагам и затем расцветают, попадание основной атакой во врагов с цветком создаёт небольшой взрыв.
		}

		possessedHatchet: {
			Label: "[i/s1:1122] Переработка одержимого топорика"
			Tooltip: Улучшает самонаведение топорика и даёт ему новый эффект попадания.
		}

		leafClaymore: {
			Label: "[i/s1:1226] Переработка хлорофитового клеймора"
			Tooltip: Перерабатывает анимацию атаки клеймора и даёт ему возможность заряда, удерживая ЛКМ.
		}

		leafSaber: {
			Label: "[i/s1:1227] Переработка хлорофитовой сабли"
			Tooltip: Перерабатывает анимацию атаки сабли и изменяет принцип появления спор.
		}

		leafPartisan: {
			Label: "[i/s1:1228] Переработка хлорофитового протазана"
			Tooltip: Перерабатывает анимацию атаки и даёт дополнительную третью атаку.
		}

		stynger: {
			Label: "[i/s1:1258] Переработка Стингера"
			Tooltip: Перерабатывает анимацию атаки Стингера, механику перезарядки и альтернативный режим атаки.
		}

		heatRay: {
			Label: "[i/s1:1295] Переработка теплового излучателя"
			Tooltip: Даёт лучу механику перегрева, увеличивающую его урон и давая возможность поджигать и снижать защиту врагов.
		}

		deathSickle: {
		    Label: "[i/s1:1327] Переработка косы смерти"
			Tooltip: Перерабатывает анимацию атаки Косы смерти; каждая третья атака бросает косу в сторону курсора.
		}

		pulseBow: {
			Label: "[i/s1:2223] Переработка пульсирующего лука"
			Tooltip:
				'''
				Меняет поведение пульсирующих болтов, давая им возможность отскакивать в сторону врагов. Даёт оружию механику зарядки.
				Оружие получает улучшенное синергирование с Грибнитовой броней, позволяя её носителю оставаться в невидимости даже во время атаки.
				Но лук, в свою очередь, невидимым не становится, позволяя видеть процесс заряда.
				'''
		}

		LMG: {
			Label: "[i/s1:2795] Переработка лазерного пулемёта"
			Tooltip: Пулемёт перестаёт стреляет во время набора скорости, но взамен даёт щит.
		}

		chainsaw: {
			Label: "[i/s1:3098] Переработка бензопилы мясника"
			Tooltip:
				'''
				Бензопила мясника теперь имеет механику нагревания и увеличенную скорость атаки.
				Оружие способно временно задерживать игрока в воздухе при постоянном нанесении урона по врагам.
				'''
		}

		shinyStone: {
			Label: "[i/s1:3337] Переработка сияющего камня"
			Tooltip: Сияющий камень теперь даёт временное усиление к защите, в зависимости от потерянного здоровья и улучшает характеристики целителя, если включён Thorium.
		}

		maceWhip: {
			Label: "[i/s1:4679] Переработка утренней звезды"
			Tooltip: Перерабатывает анимацию атаки утренней звезды; каждая вторая атака отбрасывает хлыст назад; а третья атака раскручивает его вокруг игрока.
		}

		scytheWhip: {
			Label: "[i/s1:4680] Переработка тёмной жатвы"
			Tooltip: Перерабатывает анимацию атаки тёмной жатвы; каждая вторая атака раскручивает хлыст вокруг игрока; а третья атака бросает косы в сторону курсора, прошивающие врагов насквозь.
		}
	}
}
