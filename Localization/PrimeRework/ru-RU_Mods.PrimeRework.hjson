Configs: {
	ReworkConfig: {
		DisplayName: Конфигурация переработок

		twins: {
			Label: "[i/s1:544] Переработка Близнецов"
			Tooltip:
				'''
				Включает/Выключает переработку Близнецов. 
				Если эта переработка конфликтует с другими модами, вы можете её легко отключить.
				Настройка работает с режимами Вечность и Месть, так что отключать её не нужно, даже если одна из этих сложностей включена.
				(ПРИМЕЧАНИЕ: Паттерны атак комбинируются, не заменяются!)
				'''
		}

		destroyer: {
			Label: "[i/s1:556] Переработка Уничтожителя"
			Tooltip:
				'''
				Включает/Выключает переработку Уничтожителя. 
				Если эта переработка конфликтует с другими модами, вы можете её легко отключить.
				Настройка работает с режимами Вечность и Месть, так что отключать её не нужно, даже если одна из этих сложностей включена.
				(ПРИМЕЧАНИЕ: Паттерны атак комбинируются, не заменяются!)
				'''
		}

		prime: {
			Label: "[i/s1:557] Переработка Скелетрона Прайма"
			Tooltip:
				'''
				Включает/Выключает переработку Скелетрона Прайма.
				Если эта переработка конфликтует с другими модами, вы можете её легко отключить.
				Настройка работает с режимами Вечность и Месть, так что отключать её не нужно, даже если одна из этих сложностей включена.
				(ПРИМЕЧАНИЕ: Паттерны атак комбинируются, не заменяются!)
				'''
		}

		oldAI: {
			Label: Старые переработки ИИ
			Tooltip:
				'''
				Включает/Выключает старые версии переработок боссов.
				Старый ИИ есть только у Уничтожителя.
				'''
		}

		Death: {
			Label: Анимации смерти
			Tooltip: Включает/Выключает анимации смерти механических боссов.
		}

		masterDropsAreNonExclusive: {
			Label: Оружие Мастера становится Экспертным
			Tooltip:
				'''
				Эксклюзивное для режима Мастер оружие после включения опции сможет выпадать и на сложности Эксперт.
				Рекомендуется, если вам не нравится режим Мастер или другие моды мешают в него играть.
				(Например режим Вечность на Мастере становится Мазохистом, а Инфернум не позволяет играть на Мастере вообще)
				'''
		}

		dayMechs: {
