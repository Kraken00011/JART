	MechclopsTrophy: {
		DisplayName: Трофей Ст4-зис
		Tooltip: ""
	}

	OverloadScope: {
		DisplayName: Перегруженный прицел
		Tooltip:
			'''
			Нажмите ПКМ, чтобы отдалить с любым оружием в руках
			Удерживайте ПКМ, чтобы начать медленно прицеливаться
			После успешного прицеливания накладывает метку на ближайшего к курсору врага
			Попадание по отмеченному врагу вызовет мощный взрыв
			Враг, поражённый любым дебаффом, может взорваться сам по себе
			'''
