BossThreats: {
	TwinsDay: Это будет кошмарный день...
	Terminator: Вы чувствуете чье-то злобное присутствие...
	Caretaker: Вы слышите странное жужжание...
	Mechclops: Вы слышите отдалённый грохот стали...
}

ItemDescriptions: {
	AdamantiteArmor:
		'''
		При нанесении урона призывает адамантитовые пики, вращающиеся вокруг игрока
		Всего может быть активно до трёх пик
		Со временем пики превращаются в различные подбираемые бонусы
		'''
	BeamSword: При попадании меч создаёт свою копию
	CobaltArmor:
		'''
		Увеличивает защиту и сопротивление урону соразмерно снижению вашего здоровья
		Максимально может увеличить защиту на 25 ед., а сопротивление урону на 20%
		Эффект активируется начиная с {0} ед. здоровья
		'''
	Excalibur: При нанесении критического удара временно увеличивает скорость атаки
	HallowedSummonerArmor:
		'''
		Увеличивает дальность хлыстов на 15%
		Призывает зачарованный меч, атакующий врагов
		'''
	MythrilArmor:
		'''
		Значительно увеличивает скорость атаки, если вы не наносили урон некоторое время
		Эффект длится до 5 секунд и заряжается около 3 секунд
		'''
	Megashark: Во время стрельбы иногда выпускает акуловидную ракету
	MagicDagger: Со временем разделяется на 6 кинжалов
	Phasesabers:
		'''
		Полностью игнорирует вражескую броню
		Совершение взмаха в нужный момент отражает снаряд обратно во врага, нанося 1000% урона
		'''
}

SpawnConditions: {
	Generic: Используйте [i:{0}] где угодно, когда угодно.
	Mechdusa: Используйте [i:{0}] в генерации мира «Zenith» или в обычном мире после победы над Големом.
	SiegeEngine: Используйте [i:{0}] у границ преисподней, чтобы пробудить древнюю конструкцию.
}

Tiles: {
	SoulofDightinaBottle.MapEntry: Эссенция оберегания в банке
	SoulofFreightinaBottle.MapEntry: Эссенция страха в банке
	SoulofPlightinaBottle.MapEntry: Эссенция боли в банке
	SoulofTightinaBottle.MapEntry: Эссенция сплочения в банке
}

Buffs: {
	AdamantiteSpades: {
		DisplayName: Адамантитовые пики
		Description: Множество адамантитовых пик кружат вокруг вас
	}

	ExcaliburRage: {
		DisplayName: Гнев Артура
		Description: Скорость атаки ближнего боя увеличена на 33%
	}

	ElectromagneticFlux: {
		DisplayName: Электромагнитный мех
		Description:
			'''
			Урон и скорость атаки увеличены на 10%, бесконечный полёт
			'Вы чувствуете себя усиленным!'
			'''
	}

	Flinxcopter: {
