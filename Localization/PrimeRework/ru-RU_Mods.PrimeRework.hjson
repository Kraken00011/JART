			'''
			Скорее, дотроньтесь до пурпурных клонов, пока не стало слишком поздно!
			(Вы получите урон, если выберите неправильный цвет)
			'''
	}

	MarkedforNegationNeutral: {
		DisplayName: Посмертно отмеченный (Нейтральный заряд)
		Description:
			'''
			Скорее, дотроньтесь до жёлтых клонов, пока не стало слишком поздно!
			(Вы получите урон, если выберите неправильный цвет)
			'''
	}

	MarkedforNegationPositive: {
		DisplayName: Посмертно отмеченный (Положительный заряд)
		Description:
			'''
			Скорее, дотроньтесь до голубых клонов, пока не стало слишком поздно!
			(Вы получите урон, если выберите неправильный цвет)
			'''
	}

	MechanicalJet: {
		DisplayName: Механический истребитель
		Description: Богоподобная скорость!
	}

	MissileBattery: {
		DisplayName: Ракетный ранец
		Description: Сливает IP адреса ваших противников
	}

	Nanny: {
		DisplayName: B-33 «Нянька»
		Description: "'Она сможет помочь вам наконец-то выспаться'"
	}

	RockCancer: {
		DisplayName: Каменный рак
		Description: Ваша кровь кристаллизуется...
	}

	Safesys: {
		DisplayName: М0р-0з
		Description: Кажется, он куда больше изнутри!
	}

	Termini: {
		DisplayName: Термини
		Description: Слушай... да эта милаха и мухи не обидит!
	}
}

Items: {
	AbominationRemote: {
		DisplayName: Подозрительно выглядящая коробка
		Tooltip:
			'''
			На ней располагается записка с очень странной поэмой, в поэме есть несколько выделенных слов:
			'Ты - не [c/00FFFF:ровня] тому, что скрывается внутри неё.'
			'Ты встретишься лицом к лицу с [c/FFFF00:тем], что называется последствия своих действий!'
			'О, пусть тёмные [c/FF00FF:цвета] ночного неба преследуют тебя даже во сне...'
			'О, пусть оно [c/FF0000:уничтожит] все твои желания!'
			'Да пусть твари из тьмы наконец поймают тебя уже за [c/00FF00:хвост].'
			'И наконец, пусть каждые [c/0000FF:сегменты] твоего тела будут стёрты и превращены в безжизненные угли.'
			Возможно, эти слова - подсказка к тому, с чем вам предстоит сразиться...
			'''
	}

	AdvancedCombinationLock: {
		DisplayName: Улучшенный кодовый замок
		Tooltip:
			'''
			Призывает крохотного меха-оленя, хранящего за вас предметы, а также способного охлаждать ваши напитки!
			Сейф меха-оленя имеет бесконечный радиус действия, ведь он всегда поспевает за вами
			'Его кодовый замок такой мелкий и довольно-таки сложно дешифруемый, но к счастью у него есть функция распознавания лица!'
			'''
	}

	Anemoscepter: {
		DisplayName: Анемопосох
		Tooltip: 
			'''
			Удерживайте ЛКМ, чтобы зарядить атаку
			При полной зарядке отпустите, чтобы выстрелить небольшим, но мощным вихрем
			'''
	}

	ArtificialStinger: {
		DisplayName: Искусственный Стингер
		Tooltip:
			'''
			Использует дротики и стрелы в качестве боеприпасов
			Сверхзаряжает загруженные боеприпасы, делая их сильнее
			Усиленные стрелы при попадании оставляют ионный след
			Нажмите ПКМ, чтобы зарядить магнитные дротики, втыкающиеся во врагов
			Заряженные стрелы самонаводятся на врагов с воткнутыми магнитными дротиками
			'Создан, чтобы стимулировать боль тысячи жал'
			'''
	}

	Avalanche: {
		DisplayName: Лавина
		Tooltip:
			'''
			Использует снежки в качестве боеприпасов
			Заряжайте оружие, чтобы увеличить максимальное количество выпускаемых снежков
			При полном заряде, снежки наполняются шрапнелью
			'Нет, оно не готовит мороженное'
			'''
	}

	BeeController: {
		DisplayName: Пчелиный контроллер
		Tooltip:
			'''
			Призывает помощника В-33, следующего за вашим курсором
			Охлаждает владельца когда тот засыпает на кровати
			'Утром рано встаёт охрана...'
			'''
	}

	BeeRemote: {
		DisplayName: Подозрительно выглядящий меха-пчела
		Tooltip:
			'''
			Призывает «Хранителя»
			'Вы слышите странное жужжание...'
			'''
	}

	Beforeshock: {
		DisplayName: Лёгкие толчки
		Tooltip:
			'''
			Стреляет 3 залпами, в каждом из которых находится по 5 пуль
			Первый залп дополнительно вызывает массивную ударную волну в направлении курсора
			'Лёгкие толчки - постоянно повторяющиеся толчки, предвещающие начало самого землетрясения'
			'''
	}

	Bloodshed: {
		DisplayName: Кровоток
		Tooltip: ""
	}

	BloodStainedPocketWatch: {
		DisplayName: Окровавленные карманные часы
		Tooltip: Призывает окровавленные серебряные ножи, летящие в направлении курсора
	}

	BrainRemote: {
		DisplayName: Подозрительного выглядящий меха-мозг
		Tooltip:
			'''
			Призывает Терминатора
			'Вы чувствуете чьё-то злобное присутствие...'
			'''
	}

	BreachCutter: {
		DisplayName: Плазменный резак
		Tooltip:
			'''
			Стреляет двумя соединёнными сферами плазмы
			Игнорирует часть вражеской защиты
			'''
	}

	CaretakerBossBag: {
		DisplayName: Мешок с сокровищами (MK-22 «Хранитель»)
