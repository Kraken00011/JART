	}

	CaretakerRelic: {
		DisplayName: Реликвия «Хранителя»
		Tooltip: ""
	}

	CaretakerTrophy: {
		DisplayName: Трофей «Хранителя»
		Tooltip: ""
	}

	ClockworkWrench: {
		DisplayName: Заводной гаечный ключ
		Tooltip: Призывает заводную турель, стреляющую высокоскоростными пулями в ближайших врагов
	}

	DeerRemote: {
		DisplayName: Подозрительно выглядящий меха-олень
		Tooltip:
			'''
			Призывает Ст4-зис
			'Вы слышите отдалённый грохот стали...'
			'''
	}

	DoubleTrouble: {
		DisplayName: Двойная угроза
		Tooltip:
			'''
			Взмахивает либо Спазматизмом, либо Ретинайзером
			Ретинайзер стреляет лазерами, а Спазматизм проклятым пламенем
			Каждый 3 удар взмахивает и Спазматизмом и Ретинайзером одновременно
			Считается хлыстом, но бонусы к дальности хлыстов этот предмет не получает
			'''
	}

	EnergyHilt: {
		DisplayName: Энергетическая рукоять
		Tooltip:
			'''
			Атаки ближнего боя пробивают 10 ед. брони
			Лазерные сабли стреляют световой волной на небольшое расстояние
			'''
	}

	Exitium: {
		DisplayName: Ликвидация
		Tooltip:
			'''
			Взмахи копьём выпускают молнии и ракеты
			Ракеты самонаводятся на ближайшего к курсору врага
			Нажмите ПКМ, чтобы взорвать все выпущенные ракеты
			Копье атакует сквозь блоки
			'Разыскать и ликвидировать'
			'''
	}

	EyeRemote: {
		DisplayName: Подозрительно выглядящий меха-глаз
		Tooltip:
			'''
			Призывает Близнецов
			'Это будет кошмарная ночь...'
			'''
	}

	Finis: {
		DisplayName: Вопль смерти
		Tooltip:
			'''
			При каждом 3 взмахе бросает косу в направлении курсора
			Бросок косы призывает заряды, вращающиеся вокруг игрока
			Удерживайте ПКМ во время атаки, чтобы автоматически навести косу на ближайшего врага
			Попадание по врагу косой во время её броска заставит вращающиеся вокруг вас заряды самонавестись на поражённого врага
			'''
	}

	FlinxForceWalkieTalkie: {
		DisplayName: Рация флинксов
		Tooltip: Призывает флинкскоптеры, сбрасывающие бомбы на ваших врагов
	}

	HandPrime: {
		DisplayName: Прайм-рука
		Tooltip:
			'''
			Нажмите ПКМ, чтобы переключаться между 4 разными модулями
			Модуль лазера: Стреляет очередью красных лазеров
			Модуль пушки: Стреляет самонаводящимися красными ракетами
			Модуль пилы: Превращается в пилу и кромсает врагов на кусочки
			Переключение модуля или смена предмета запустят пилу в направление курсора
			Модуль пилы не может использоваться пока снаряд пилы не исчезнет
			Модуль крюка: Стреляет крюком, вонзающийся за врагов
			Нажмите ЛКМ, чтобы притянуть себя к вонзённому крюку
			'''
	}

	HarmonicWeaponCatalyst: {
		DisplayName: Гармонизированный оружейный катализатор
		Tooltip:
			'''
			Увеличивает урон, скорость атаки и шанс критического удара на 10%, а также пробивание брони на 10 ед.
			При использовании некоторых типов оружия вы будете получать дополнительные бонусы, связанные с их классом:
			[c/e51919:Воин]: Во время атаки увеличивает сопротивление урону на 10%, но враги будут чаще выбирать вас в качестве цели
			[c/00aa38:Стрелок]: Даёт 10% шанс не расходовать боеприпас и увеличивает дальность снарядов
			[c/0e81f4:Маг]: Увеличивает максимальный запас маны на 60, снижает расход маны на 10%, а также при низком здоровье даёт постоянную регенерацию маны
			[c/f87abe:Призыватель]: Увеличивает максимальное количество стражей и миньонов на 2 и враги будут реже выбирать вас в качестве цели
			[c/ffa53c:Метатель]: Увеличивает дальность метательных снарядов на 10%
			[c/ffa53c:Разбойник] (Calamity): Увеличивает максимальный запас скрытности и скорость разбойных снарядов на 10%
			[c/00ff80:Бард] (Thorium): Увеличивает максимальный запас вдохновения на 4, длительность усилений на 5 секунд и радиус действия усилений на 15 блоков
			[c/ffff5b:Целитель] (Thorium): Снижает расход маны на 10%, исцеляющие заклинания восстанавливают дополнительно 2 ед. здоровья
			[c/7746d7:Пустота] (Secret of the Shadows): Снижает урон от дебаффов «Пустотный шок» и «Пустотное восстановление»
			'''
	}

	Jumboshark: {
		DisplayName: Джамбо-акула
		Tooltip:
			'''
			Дальний родственник мини-акулы
			Стреляет 3 пулями за атаку
			'''
	}

	Killswitch: {
		DisplayName: Аварийный механизм
		Tooltip:
			'''
			Призывает Термини, следующего за вами
			'Да что ты? Он и мухи не обидит!'
			'''
	}

	KineticTremors: {
		DisplayName: Кинетический сотрясатель
		Tooltip:
			'''
			Удерживайте ЛКМ, чтобы зарядить огромный молот, вызывающий ударные волны при столкновении с блоками или врагами
			Молот может вызывать множество ударных волн подряд, позволяя наносить урон несколько раз за одну атаку
			'При выплавке было использовано немного... боеголовок'
			'''
	}

	HydraulicPressManual: {
		DisplayName: Руководство по гидравлике
		Tooltip:
			'''
			Щёлкните по врагу, чтобы сдавить его гидравлическим прессом
			'Своеобразный АСМР'
			'''
	}

	LaserStar: {
		DisplayName: Лазерная звезда
		Tooltip: Попадание по врагу создаёт лазерные лучи
	}

	MechanicalCockpitPiece: {
		DisplayName: Механическая деталь кабины
		Tooltip: ""
	}

	MechanicalJet: {
		DisplayName: Механический истребитель
		Tooltip:
			'''
			Призывает быстрый, парящий в воздухе истребитель
			После разгона до максимальной скорости начинает наносить контактный урон
			Любые атаки выпускают множество ракет, урон которых зависит от вашей скорости атаки
			'По крайней мере, в этом мире легко достать топливо для истребителей'
			'''
	}

	MechanicalWings: {
		DisplayName: Механический ранец
		Tooltip:
			'''
			Позволяет летать и плавно парить
			Нажмите ВНИЗ, чтобы парить
			Нажмите ВВЕРХ, чтобы перестать парить
			Удерживайте ВВЕРХ, чтобы ускориться!
			Удерживайте ВНИЗ пока вы вне полёта, чтобы ускорить падение!
			'Создаётся проще, а работает даже лучше!'
			'''
	}

	MechclopsBossBag: {
		DisplayName: Мешок с сокровищами (Ст4-зис)
		Tooltip: "{$CommonItemTooltip.RightClickToOpen}"
	}

	MechclopsMask: {
