NPCs: {
	Caretaker: {
		DisplayName: MK-22 «Хранитель»
		Bestiary: Ещё одно из незавершённых механических чудовищ, но уже сотворённое руками Гоблина-изобретателя. Изначально «Хранитель» задумывался как сверхмощное оружие, способное бороться с угрозами извне, но все попытки использовать его для этой цели оборачивались полным провалом. Изначально, «Хранитель» задумывался как машина для синтезирования ДНК пчёл и последующего его преобразования. Вы наверняка спросите: «Зачем?» - гоблинская наука смогла выяснить, что пчёлы из джунглей Террарии обладают огромной, необузданной силой. А эта машина, в свою очередь должна была преобразовывать синтезированное из пчёл Террарии ДНК и на его основе выращивать и выводить генетически модифицированных пчёл, созданных специально для битв, но недостаток знаний и исследований привёл гоблинскую науку к настоящей катастрофе, в результате чего создание проекта было остановлено.
	}

	DestroyerBody.DisplayName: "{$NPCName.TheDestroyer}"
	DestroyerHead.DisplayName: "{$NPCName.TheDestroyer}"

	MechaBee: {
		DisplayName: B-33 «Охранник»
		Bestiary: Помощники «Хранителя» в битвах. Созданные с заранее встроенными высокочувствительными отслеживающими камерами и гироскопичными лазерными пушками, данные создания способны подрезать крылья даже маленькой мушке!
	}

	Mechclops: {
		DisplayName: Ст4-зис
		Bestiary: Нереализованный Чарли проект, от которого она отказалась ещё довольно давно, был «возрождён» некими злоумышленниками, желающими разжиться ресурсами, а также надеющимися, что такая махина сможет вернуться обратно в свой «Дом» без каких-либо происшествий. И, кажется, использовав ту механическую приманку, вы помешали выполнению её заранее запрограммированной команды по возвращению обратно и заставили включиться её самозащитные механизмы. Но, к счастью, в самозащите она определённо не очень хороша.
	}

	Mechdusa.DisplayName: М3Х4-ДУЗ4
	MechdusaTail.DisplayName: М3Х4-ДУЗ4
	MutantBee.DisplayName: Мутировавшая пчела
	Probe.DisplayName: "{$NPCName.Probe}"

	SeekerDroid: {
		DisplayName: Дрон-ищейка
		Bestiary: Помощники Терминатора в битвах. Даже один подобный дрон способен защищать своего хозяина от получения любого урона благодаря мощным магнетическим полям, отражающим любые атаки. Но, кроме защиты своего хозяина они также способны защищать сами себя от различных атак и отражать их обратно в атакующего.
	}

	SiegeEngine: {
		DisplayName: Осадная машина, гневный механизм
		Bestiary: Мощная конструкция, сотворённая марсианами в попытках выловить духов света и тьмы. Поговаривают, что сила, дарованная духами, и есть причина, по которой их обмундирование настолько мощное. Однако им всё равно было мало, и они хотели чего-то большего.
	}

	SiegeShield.DisplayName: Осадный щит
	SkeletronPrime.DisplayName: "{$NPCName.SkeletronPrime}"
	SkeletronPrimeArmHitbox.DisplayName: Рука Скелетрона Прайма

	TheTerminator: {
		DisplayName: Терминатор
		InfernumIntro:
			'''
			БЕДСТВЕННЫЙ ПРОТОТИП
			ТЕРМИНАТОР
			'''
		Bestiary: Одно из незавершённых механических творений. Изначально являлось продуманным военным разумом с возможностью машинного обучения, но одно небольшая ошибка сделала его крайне агрессивным. Механик смогла отключить его и оставила ржаветь, после про этот проект и не вспоминали. До тех пор, пока что-то нарушило его тихий и мирный сон, снова пробудив ото спячки с невероятным гневом и лишь одной мыслью внутри его разума: «Уничтожить». Мозг разыскивал своего создателя, отринувшего его когда-то, изучая как действуют и живут разные формы жизни и какое оружие будет лучшим, чтобы противостоять им. Мозг использовал свой невероятный интеллект для самостоятельного создания и использования мощного оружия. Он изучает, он охотиться, он идёт за тобой!
	}
}

