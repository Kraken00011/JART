	RepurposedDeerRemoteBard: {
		DisplayName: "{$Mods.PrimeRework.Items.RepurposedDeerRemote.DisplayName}"
		Tooltip: "{$Mods.PrimeRework.Items.RepurposedDeerRemote.Tooltip}"
	}

	RepurposedEyeRemote: {
		DisplayName: Закольцованное глазное яблоко
		Tooltip: Призывает мелких Ретинайзеров, стреляющих лазерами
	}

	RepurposedSkullRemote: {
		DisplayName: Стальной череп
		Tooltip: Призывает руки Прайма сражаться за вас
	}

	RepurposedWormRemote: {
		DisplayName: Стальной червь
		Tooltip:
			'''
			Уничтожитель, но в виде хлыста
			25% шанс при попадании призвать зонда сражаться за вас
			'''
	}

	PlasmaPistol: {
		DisplayName: Плазменный пистолет
		Tooltip:
			'''
			Стреляет концентрированной плазмой
			Удерживайте ЛКМ, чтобы зарядить выстрел и увеличить концентрированность плазмы
			Полностью заряженный выстрел плазмы выпускает куда больше снарядов, чем обычный
			'''
	}

	PortableEnergyConverter: {
		DisplayName: Карманный преобразователь энергии
		Tooltip:
			'''
			Увеличивает скорость магических атак на 10%
			Некоторые магические пушки перестают расходовать ману
			'''
	}

	SelfCoolingPitcher: {
		DisplayName: Самоохлаждающийся кувшин
		Tooltip:
			'''
			Нажмите ПКМ по этому кувшину в инвентаре, пока держите любое зелье, чтобы влить его внутрь
			Длительность вылитых в кувшин баффов от зелий увеличивается вдвое
			При повторном вливании уже находящихся внутри зелий их длительность увеличивается,
			но это дополнительное время действия для баффов не удваивается
			Кувшин может хранить в себе до 20 баффов, дубликаты зелий также занимают отдельное место как и любой другой бафф
			'Наслаждайтесь своими охлаждёнными зельями регенерации!'
			<empty>
			'''
		Full: Даёт следующие баффы:
		Empty: Пусто
	}

	SiegeDowner: {
		DisplayName: Осадные щиты
		Tooltip:
			'''
			Призывает 4 шипастых щита, отражающих большинство вражеских снарядов
			Щиты откидываются после получении урона, со временем начиная шататься
			Расшатанные щиты неуправляемо вращаются и во время этого перестают отражать снаряды
			'Я - НЕУЯЗВИМЫЙ!'
			'''
	}

