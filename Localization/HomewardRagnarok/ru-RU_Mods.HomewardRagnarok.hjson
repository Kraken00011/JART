Mods: {
	HomewardRagnarok: {
		CoJIntro: {
			GoblinChariot:
				'''
				НЕУПРАВЛЯЕМАЯ БОЕВАЯ МАШИНА
				ГОБЛИНСКАЯ КОЛЕСНИЦА
				'''
			PuppetOpera:
				'''
				НИТИ СУДЬБЫ
				КУКОЛЬНАЯ ОПЕРА
				'''
			BigDipper:
				'''
				ЗВЕЗДОРОЖДЁННЫЙ СТРАННИК
				БОЛЬШАЯ МЕДВЕДИЦА
				'''
			MarquisMoonsquid:
				'''
				ТИРАН БЕЗДНЫ
				МАРКИЗ, ЛУННЫЙ КАЛЬМАР
				'''
			PriestessRod:
				'''
				ВЕСТНИК СВЯТОСТИ
				ЖРИЦА СТЕРЖНЕЙ
				'''
			Diver:
				'''
				ЗАЩИТНИК ГЛУБИН
				ДАЙВЕР
				'''
			TheMotherbrain:
				'''
				МАСТЕР МАХИНАЦИЙ
				МАТЕРИНСКИЙ МОЗГ
				'''
			WallofShadow:
				'''
				ПОРОЖДЕНИЕ ТЬМЫ
				СТЕНА ТЕНЕЙ
				'''
			SlimeGod:
				'''
				ПЕРВОРОДНЫЙ СЛИЗЕНЬ
				БОГ СЛИЗНЕЙ: РЕВАНШ
				'''
			TheOverwatcher:
				'''
				ВЫСШИЙ СТРАЖ ВРЕМЕНИ
				ЧАСОВОЙ
				'''
			TheLifebringerHead:
				'''
				РОСТОК БОЖЕСТВЕННОСТИ
				ЖИЗНЕНОСЕЦ
				'''
			TheMaterealizer:
				'''
				ТВОРЕЦ РЕАЛЬНОСТЕЙ
				МАТЕРИАЛИЗАТОР
				'''
			ScarabBelief:
				'''
				ДРЕВНЯЯ СВЯЗЬ
				ВЕРА СКАРАБЕЯ
				'''
			WorldsEndEverlastingFallingWhale:
				'''
				КРУШИТЕЛЬ ПУСТОТ
				ВЕЧНО ПАДАЮЩИЙ КИТ КОНЦА СВЕТА
				'''
			TheSon:
				'''
				ГОСПОДИ ПОМИЛУЙ
				СЫН
				'''
		}
	}
}

FlamethrowerEx.HomewardRagnarok.SulphuricScaleEffect: Пламя накладывает 6-секундный дебафф [cbuff:CalamityMod/Irradiated]

Configs: {
	ServerConfig: {
		DisplayName: Серверная конфигурация

		Headers: {
			MainCategory: Основное
			WeaponChanges: Изменения оружия
			ArmorChanges: Изменения брони
			ModChanges: Совместимость
		}

		EnableBossScaling: {
			Label: "[i:ContinentOfJourney/SolarFlareScoria] Масштабирование характеристик боссов"
			Tooltip: Если включено, характеристики боссов из HWJ, будут масштабироваться в зависимости от включённых модов.
		}

		HWJRecipes: {
			Label: "[i:ContinentOfJourney/FinalBar] Улучшение рецептов HWJ"
			Tooltip: Если включено, балансирует рецепты из HWJ, чтобы они лучше подходили под прогрессию других модов.
		}

		EnableBookmarks: {
			Label: "[i:ContinentOfJourney/EruditeBookmark] Книжные закладки"
			Tooltip: Если включено, позволяет магическому оружию из модов работать со страницами заклинаний.
		}

		CustomContent: {
			Label: "[i:HomewardRagnarok/RogueBadge] Дополнительный контент"
			Tooltip: Если включено, добавляет новый контент, заполняющий некоторые пробелы в игровой прогрессии.
		}

		BloodOrbPotions: {
			Label: "[i:CalamityMod/BloodOrb] Раздваивание зелий с помощью кровавых сфер"
			Tooltip: Если включено, зелья из HWJ, смогут раздваиваться с помощью кровавых сфер из Calamity.
		}

		CustomStealthStrikes: {
			Label: "[i:ContinentOfJourney/RisingAction] Скрытные удары"
			Tooltip: Если включено, даёт некоторому оружию из HWJ уникальные скрытные удары.
		}

		EnableRogueClassChanges: {
			Label: "[i:ContinentOfJourney/Fission] Объединить класс метателя"
			Tooltip: Если включено, метательное оружие из HWJ, станет оружием класса метатель.
		}

		EnableMeleeClassChanges: {
			Label: "[i:ContinentOfJourney/Shoreline] Объединить класс воина"
			Tooltip: Если включено, некоторое оружие из HWJ, станет оружием ближнего боя.
		}

		EnableHealerClassChanges: {
			Label: "[i:ContinentOfJourney/DaCapo] Объединить класс целителя"
			Tooltip: Если включено, косы из HWJ, станут оружием класса целитель из Thorium.
		}

		WeaponBalancing: {
			Label: "[i:ContinentOfJourney/StarEaterStaff] Перебалансировка оружия"
			Tooltip: Если включено, оружие из HWJ будет перебалансировано для получения лучшего игрового опыта с другими модами.
		}

		ArmorBalancing: {
			Label: "[i:ContinentOfJourney/WatchmanHat] Перебалансировка брони"
			Tooltip: Если включено, броня из HWJ будет перебалансирована для получения лучшего игрового опыта с другими модами.
		}

		ArmorCraft: {
			Label: "[i:ContinentOfJourney/EquilibriumBreastplate] Обновление рецептов брони"
			Tooltip: Если включено, рецепты брони из HWJ будут объединены с рецептами из других модов.
		}

		CalamityBalance: {
			Label: Совместимость с Calamity
			Tooltip: Если включено, объединяет аксессуары, оружие и рецепты из Calamity с Homeward Journey.
		}

		ClamityBalance: {
			Label: Совместимость с Clamity
			Tooltip: Если включено, немного изменяет пару аксессуаров и оружия из Clamity для лучшего игрового опыта с Homeward Journey.
		}

		ThoriumBalance: {
			Label: Совместимость с Thorium
			Tooltip: Если включено, объединяет некоторые аксессуары целителя и рецепты из Thorium с Homeward Journey, также имеет поддержку для аддонов Thorium.
		}

		SOTSBalance: {
			Label: Совместимость с SOTS
			Tooltip: Если включено, немного меняет рецепты из Secrets Of The Shadows и Unofficial SOTS Bard, Thrower and Healer.
		}

		ConsolariaBalance: {
			Label: Совместимость с Consolaria
			Tooltip: Если включено, объединяет эссенции отравления из обоих модов в один предмет.
		}
	}
}

ModCompat.BossChecklist.SlimeGod: Бог слизней: Реванш

ItemTooltips: {
	OmniShield: -Универсальный щит-
	ImmunityVulnerable: Даёт невосприимчивость к дебаффу [cbuff:ContinentOfJourney/VulnerableBuff]
	CommemorativeCoin: Снижает урон от дебаффов на 35%
	TransactionCertificate: Предотвращает смерть, оставляя игроку 1 ед. здоровья; 10 минут перезарядки
	SteamkeeperWatch: Призванные стражи существую бесконечно и увеличивают свой урон на 15% в течении первых 2-х минут
	HungeringBlossom: Даёт эффекты от предмета «Жаждущий цветок», если видимость предмета отключена
	ConstructionPDA: Увеличивает максимальное количество миньонов на 1
	DivineNecklace: Атаки миньонов накладывают дебафф [cbuff:ContinentOfJourney/DivineFireBuff]
	ToggleWings: Нажмите Shift+ПКМ по этому предмету в инвентаре, чтобы переключить [i:493] крылья
	AbyssCore: Освещает место вашего курсора
	GrandSpectral:
		'''
		Увеличивает длительность неуязвимости после получения урона
		Призывает спектральных духов при получении или нанесении урона
		'''
	LampreyScarf:
		'''
		Призывает шарф-миногу
		Увеличивает дальность хлыстов на 10%
		Увеличивает максимальное количество стражей на 2
		'''
	ArmillarySphere: Ваши стражи формируют созвездие, наносящее 50% урона от находящегося в ваших руках оружия
	"Remove'Range'": Дальность
	"Remove'range'": дальность
	SpikyCoverRework: Кончик хлыста наносит в 1,5 раза больше урона и накладывает дебафф [cbuff:Bleeding]
	CrossbowScope:
		'''
		Увеличивает стрелковый урон на 5%
		Увеличивает шанс стрелкового критического удара на 7%
		Враги реже выбирают вас в качестве цели
		Увеличивает урон стрел
		Конвертирует деревянные стрелы в священные
		Отображает траекторию полёта пуль для огнестрельного оружия
		'''
	DivineTouch: Атаки и снаряды ближнего боя накладывают дебафф [cbuff:ContinentOfJourney/DivineFireBuff]
	
	EtherealTalisman: {
		OrigTooltip1: Увеличивает максимальный запас маны 150 и снижает расход маны на 10%
