		DisplayName: Значок разбойника
		Tooltip:
			'''
			Увеличивает разбойный урон на 20%
			Увеличивает шанс разбойного критического удара на 5%
			'''
	}

	BrokenChest: {
		DisplayName: Сломанная грудная клетка
		Tooltip:
			'''
			Призывает Материализатора где угодно
			Не расходуется
			'''
	}

	EternalClock: {
		DisplayName: Вечные часы
		Tooltip:
			'''
			Призывает Часового где угодно
			Не расходуется
			'''
	}

	ScarabIdol: {
		DisplayName: Идол скарабея
		Tooltip:
			'''
			Призывает Веру скарабея где угодно
			Не расходуется
			'''
	}

	HerbalistPouch: {
		DisplayName: Подсумок травника
		Tooltip:
			'''
			Атаки йо-йо накладывают дебаффы [cbuff:Frostburn] и [cbuff:Venom], а также имеют шанс заморозить противника
			Нанесение урона с помощью йо-йо даёт вам 10% сопротивления урону, пока вы его не получите
			При получении урона эффект уйдёт на перезарядку в 15 секунд
			Нанося урон с помощью йо-йо вы заряжаете лиственный щит
			Щит полностью зарядится после 10 успешных попаданий
			Щит увеличивает сопротивление урону вплоть до 21%, пока вы его не получите
			При прекращении атаки щит запускается в направлении курсора
			'''
	}

	EvilFlask: {
		DisplayName: Гнилой флакон
		Tooltip:
			'''
			Даёт 20% шанс не потратить гель при использовании огнемёта
			Позволяет улучшать снаряды используемого огнемёта
			Огнемёты накладывают дебафф [cbuff:CalamityMod/BrainRot]
			При ношении отображает, какие предметы можно положить в пробирку и какие эффекты они дают
			Всего вы можете положить в пробирки только 2 предмета
			'''
	}

	TimelessFountainItem: {
		DisplayName: Безвременный фонтан
		Tooltip: Работает как фонтан жизни, материи и времени
	}

	NegablastShield: {
		DisplayName: Взрывной нега-щит
		Tooltip:
			'''
			50 ед. базового урона
			Даёт невосприимчивость к отбрасыванию; враги чаще выбирают вас в качестве цели
			Немного увеличивает длительность неуязвимости после получения урона
			Увеличивает сопротивление урону на 10%
			При получении урона вокруг вас происходит мощный взрыв
			Каждые 3 секунды усиливает взрыв
			Урон от взрыва масштабируется соразмерно защите
			'''
	}

	BabyOil: {
		DisplayName: Детское масло
		Tooltip:
			'''
			При получении урона с вас соскальзывает от трёх до пяти капель детского масла
			Капли наносят урон врагам
			'''
		Contributor: - Предмет участника -
	}

	TheBibleOfTheThrowerVol4: {
		DisplayName: Библия метателя
		Tooltip:
			'''
			Увеличивает метательный урон на 20%
			Увеличивает скорость метательных снарядов на 50%
			Совершает взмах битой на небольшое расстояние при использовании метательного оружия
			Призывает 3 кольца, кружащих вокруг вас и усиливающих	 ваши метательные снаряды
			Увеличивает скорость метательных атак на 20%
			При ношении в руках метельного оружия увеличивает ускорение на 75%
			Наносит дополнительный удар в размере 17,5% метательного урона
			'''
		NoExhaustion: Устраняет изматывание от использования метательного оружия
	}

	DeluxeDewCollector: {
		DisplayName: Собиратель росы де-люкс
		Tooltip:
			'''
			Лечение союзника даёт ему 2 ед. восполнения здоровья и создаёт росу
			Подбор росы увеличивает ваше собственное восполнение здоровья на 4 ед.
			Исцеляющие заклинания восстанавливают дополнительно 6 ед. здоровья
