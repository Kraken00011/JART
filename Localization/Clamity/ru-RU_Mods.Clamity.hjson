    NPCs: {
        ClamitasBoss: {
            DisplayName: Каламидия, высшая мидия
            Bestiary: Будучи проклятой самой Каламитас, гигантский моллюск впитал в себя силу серы. Когда в нёй не осталось ни капли силы океана, она превратился в Кламити, силе которой никто не может противостоять.
            BossChecklistIntegration: {
                SpawnInfo: Используйте [i:Clamity/ClamitasSummoningItem] в серных скалах.
