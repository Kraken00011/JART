Items: {
	Mounts: {
		FlameCube: {
			DisplayName: Пламенный бокс
			Tooltip:
				'''
				Материализует довольно уютный и чрезвычайно манёвренный летающий трон Каламитас
				Удерживайте [KEY], сидя на троне, чтобы двигаться медленнее для более точного позиционирования
				'Геймер в удобной позе - опасный геймер'
				'''
		}

		PlagueStation: {
			DisplayName: Чумная станция
			Tooltip:
				'''
				Материализует умеренно уютный и довольно-таки манёвренный летающий чумной трон
				Удерживайте [KEY], сидя на троне, чтобы двигаться медленнее для более точного позиционирования
				'Радикальный геймер-фанат - очумительный геймер'
				'''
		}
	}

	Weapons: {
		Typeless: {
			GoldenGun: {
				DisplayName: Позолоченный пистолет
				Tooltip: Стреляет прямым потоком чистого ихора
			}

			AMS: {
				DisplayName: A M S
				Tooltip:
					'''
					Бросает бомбы, расходуя ману
