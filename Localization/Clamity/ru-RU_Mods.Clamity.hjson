			WitherOnAStick: {
				DisplayName: Иссушитель на палочке
				Tooltip:
					'''
					'Ну спасибочки! Разработчики просто уничтожили моего любимого аликорна на палочке
					И теперь, его внешность полная хрень ([i:CalamityMod/ColdheartIcicle]Сосулька холодного сердца)
					Вот поэтому я и решил сделать свою палочку'
					- WitherTaco, Тот самый владелец Clamity Addon -
					'''
			}

			TrashOfMagnus: {
				DisplayName: Мусор Магнуса
				Tooltip:
					'''
					Стреляет чумными зарядами, накладывающими дебафф [cbuff:CalamityMod/Plague]
					Урон этого оружия рассчитывается на основе среднего значения бонусов всех ваших типов урона
					[c/9ABA4A:'Попытка Магнуса перейти к биологическому терроризму.]
					[c/9ABA4A:Несмотря на его усилия, она была признана неудачной и отброшена.']
					'''
			}

			EyeOfNova: {
				DisplayName: Око Новы
				Tooltip:
					'''
					Выпускает самонаводящимися экзо-сгустки, восстанавливающие здоровье и ману при попадании
					Взрывается облаком туманности, значительно снижающее вражеское сопротивление урону и замедляющее их
					Урон этого оружия рассчитывается на основе среднего значения бонусов всех ваших типов урона
					'''
				HoldShiftTooltip:
					'''
					При попадании накладывает дебаффы [cbuff:CalamityMod/MarkedforDeath], [cbuff:CalamityMod/Vaporfied],
					[cbuff:CalamityMod/MiracleBlight] и [cbuff:Ichor]
					'''
			}

			Celesticus: {
				DisplayName: Селестикус
				Tooltip:
					'''
					Бросает взрывные кристаллы, замедляющие врагов
					Урон этого оружия рассчитывается на основе среднего значения бонусов всех ваших типов урона
					'''
			}
		}

		Magic: {
			OmegaRay: {
				DisplayName: Омега-луч
				Tooltip: Разрушает всё пятью Y-образными лучами энергии и лазерами
			}

			Unicron: {
				DisplayName: Уникрон
				Tooltip:
					'''
					Стреляет непрерывным массивом лазеров и призывает 4-х ведомых, окружающих вас и запускающих залпы гранат и лазеров в сторону вашего курсора
					Нажмите ПКМ во время стрельбы, чтобы выстрелить Омикрон-лучом, который разделяется при попадании по врагу
					После выстрела Омикрон-лучом ведомые запускают залп гранат в сторону вашего курсора
					Попадание по врагу Омикрон-лучом сразу после выстрела значительно увеличит его урон и предотвратит его разделение
