FannyDialog: {
	Clamitas: Эй! Да она же просто огромная пародия на другого босса. Ну, что думаешь? Ай! А она горяча!
	Pyrogen: Раскалённый куб! Он выглядит также как и другие элементали. Но, только больше. Как Криоген.
	WallOfBronze: Эй! Вот эта большая металлическая стена с пушками, попробуй наносить по ней урон киркой.
	WallOfBronzeRoD: Попробуй телепортироваться за неё. Это работает не также, как со Стеной плоти.
	FrozenAncientWallOfBronze: ТУТ НИЧЕГО НЕТ!!!
	FrozenHell: Брр... как холодно. Почему в преисподней такая холодрыга? Попробуй включить обогреватель.
}

ItemExtraTootip: {
	Shortstrike: {
		Copper: Увеличивает защиту на 5 в течение 1 секунды при попадании кинжалом
		Iron: Увеличивает защиту на 6 в течение 1 секунды при попадании кинжалом
		Silver: Увеличивает защиту на 8 в течение 1 секунды при попадании кинжалом
		Gold: Увеличивает защиту на 10 в течение 1,2 секунды при попадании кинжалом
		Tin: Уменьшает получаемый урон на 2% в течение 1 секунды при попадании кинжалом
		Lead: Уменьшает получаемый урон на 3% в течение 1 секунды при попадании кинжалом
		Tungsten: Уменьшает получаемый урон на 4% в течение 1 секунды при попадании кинжалом
		Platinum: Уменьшает получаемый урон на 6% в течение 1 секунды при попадании кинжалом
		Gladius: Увеличивает скорость передвижения на 20% в течение 0,5 секунды при попадании кинжалом
	}
}

NPCs: {
	ClamitasBoss: {
		DisplayName: Каламидия, высший моллюск
		Bestiary: Будучи проклятой самой Каламитас, гигантский моллюск впитал в себя силу серы. Когда в нём не осталось ни капли силы океана, он превратился в Каламидию, силе которой никто не может противостоять.

		BossChecklistIntegration: {
			SpawnInfo: Используйте [i:Clamity/ClamitasSummoningItem] в серных скалах.
			DespawnMessage: "[c/FFD700:Каламидия возвращается в укрытие в своём гроте.]"
		}
	}

	PyrogenBoss: {
		DisplayName: Пироген
		Bestiary: Пироген - гигантская волшебная печь, созданная неизвестным кузнецом огня, содержащая большое количество эссенция огня. 'Более 1000 скоростей света в секунду!'.

		BossChecklistIntegration: {
			SpawnInfo: Используйте [i:Clamity/PyroKey] в пустыне.
			DespawnMessage: "[c/FFD700:Пироген вновь спустился в своё пылающее озеро.]"
		}
	}

	Stupid.DisplayName: Самая легендарная среди высших Каламидий Каламидия в одежде Ксерока от Supreme
	StormElemental.DisplayName: Штормовой элементаль
	PyrogenShield.DisplayName: Щит Пирогена
	WallOfBronzeTorret.DisplayName: Бронзовая турель
	WallOfBronzeLaser.DisplayName: Бронзовая лазерная машина
	WallOfBronzeClaw.DisplayName: Бронзовый коготь

	WallOfBronze: {
		DisplayName: Стена бронзы
		Bestiary: Древняя машина, хранитель более могущественных духов, чем духи из Стены плоти. Один из них может заморозить даже такое жаркое место, как преисподняя.

		BossChecklistIntegration: {
			SpawnInfo: Нажмите ПКМ по любому блоку с помощью [i:Clamity/AncientConsole] в преисподней.
			DespawnMessage: "[c/FFD700:Колоссальная машина продолжает свой вечный путь сквозь преисподнюю.]"
		}
	}

	ClockworkBat: {
		DisplayName: Бронзовая летучая мышь
		Bestiary: Бронзовые летучие мыши - это дроны Стены бронзы. Но после победы над ней они стали неуправляемыми.
	}

	GlacialSlime: {
		DisplayName: Обледенелый слизень
		Bestiary: Адский слизень, напитавшийся эссенцией мороза. Слизень пытался взорваться, но разница температур превращает его попытки в обледенелые колючки.
	}

	MetalMaw.DisplayName: Металлическая пасть
	MechanicalLeechTail.DisplayName: Механическая пиявка
	MechanicalLeechHead.DisplayName: Механическая пиявка
	MechanicalLeechBody.DisplayName: Механическая пиявка
}

