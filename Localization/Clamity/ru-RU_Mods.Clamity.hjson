				'''
		}

		DraculasCharm: {
			DisplayName: Амулет Дракулы
			Tooltip:
				'''
				Увеличивает разбойный урон на 15% и максимальную скрытность на 10
				Разбойные критические удары крадут здоровье
				При скрытном ударе увеличивает шанс критического удара и шанс кражи здоровья на 15% для всех разбойных атак, кроме скрытных на 10 секунд
				При скрытном ударе увеличивает урон на 8% и накладывает дебаффы [cbuff:CalamityMod/HeavyBleeding], и [cbuff:CalamityMod/ArmorCrunch]
				При скрытном ударе призывает рой крадущих здоровье летучих мышей-вампиров
				Разбойные снаряды взрываются при столкновении и выпускают самонаводящихся духов
				'Использование этого амулета сильно увеличивает вашу жажду крови и душ'
				'''
		}

		PyroStone: {
			DisplayName: Пирокамень
			Tooltip:
				'''
				Увеличивает урон всех накладываемых игроком дебаффов жара в 1,5 раза
