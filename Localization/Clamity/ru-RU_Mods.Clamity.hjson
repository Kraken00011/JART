Dialogues: {
	Yharim: {
		Intro: {
			Text1: Здравствуй, Террариец...
			Text2: Вот наши пути и пересеклись
			Text3: Я вижу, что ты очистил этот мир
			Text4: Я вижу побеждённых тобой богов и даже своего дракона
			Text5: И ты пришёл ко мне, в Это место...
			Text6: В Драконье гнездовье...
			Text7: Так покажи, на что ты способен!
			Text8: Покажи, насколько ты заслуживаешь победу в сравнении с другими божествами!
		}

		PlayerKilled: {
			Text1: Слаб...
			Text2: Недостаточно силён...
			Text3: Ты не достоин!
		}

		Defeated: {
			Text1: Ах, да как так!
			Text2: Ой...
			Text3: Последний богоубийца пал.
			Text4: Я не настолько силён. Я совершаю очень много ошибок...
			Text5: Это место - моя последняя битва, но не война!
			Text6: ... Продолжай свою миссию
		}
	}

	Architect: {
		Abyss: {
			Text1: Величественное создание...
			Text2: Хочешь узнать все тайны?
			Text3: Он впал в самую пустоту этого мира в порыве найти новые загадки
			Text4: Но сейчас не время для ответов.
		}

		PostWoB: {
			Text1: Великая бронзовая машина пала. Интересно...
			Text2: У тебя должно быть много вопросов по поводу своего пути.
			Text3: Кто ты? Какова твоя судьба? Как ты был рождён? И... откуда ты?
			Text4: Если ты хочешь узнать все тайны этого мира, то специально для тебя я открыл портал в самую бездну этого мира
		}
	}

	Noxus: {
		KilledYharim: {
			Text1: Хммм... Идеальный сосуд...
			Text2: Идеальное создание из хаоса
			Text3: Для Энтропии теперь на одно препятствие меньше...
		}
	}
}

