		HellFlare: {
			DisplayName: Адская вспышка
			Tooltip:
				'''
				Атаки накладывают дебафф [cbuff:OnFire3]
				Даёт невосприимчивость к дебаффам [cbuff:OnFire] и [cbuff:OnFire3]
				Увеличивает шанс критического удара на 10, если ваше здоровье выше 50%
				Увеличивает сопротивление урону на 10%, если ваше здоровье ниже 50%
				Даёт невосприимчивость к атакам холода
				'''
		}

		SupremeBarrier: {
			DisplayName: Высший барьер
			Tooltip:
				'''
				{$Mods.CalamityMod.Common.KnockbackImmunity}
				Позволяет совершать рывок, усиленный космическим инферно
				Рывок позволяет пробиваться сквозь врагов, не получая урона
				При получении урона выпускает шквал самонаводящихся звёздных пчёл[TOGGLE] и даёт бафф [cbuff:Honey]
				Даёт дополнительные кадры неуязвимости; эффект усиливается при низком здоровье или получении значительного урона
				Увеличивает сопротивление урону на 25%, если ваше здоровье ниже 50%
				Перенаправляет на владельца щита 25% урона, нанесённого игрокам вашей команды, если здоровье владельца выше 25%
				[c/aaaaaa:Нажмите Shift+ПКМ по этому предмету в инвентаре, чтобы переключить эффект] [i:PanicNecklace] [c/aaaaaa:ожерелья паники]
				'''
			ToggleEffect: ", увеличивает скорость передвижения"
		}

		IcicleRing: {
			DisplayName: Сосульковое кольцо
			Tooltip: Снижает расход маны до 0 ед., но взамен постоянно наносит урон
