EmodeBannedByInfernum: "[c/00ffee:Режим Вечность] был деактивирован [c/9c0000:режимом Инфернум]."

ActiveSkills: {
	ReaverEffect: {
		DisplayName: Адаптивность разорителя
		Tooltip:
			'''
			Переключает между покрытым и облегченным режимами
			Покрытый: Увеличивает защиту на 15 ед. и сопротивление урону на 15%
			Получение урона накладывает бафф [cbuff:CalamityMod/ReaverRage] и бросает шипастую колючку
			Облегчённый: Значительно увеличивает скорость регенерации здоровья, а также скорость и время полёта на 10%
			Снижает длительность перезарядки рывка и увеличивает скорость крюков-кошек
			'''
	}

	UmbraphileEffect: {
		DisplayName: Трансформация в стаю летучих мышей
		Tooltip:
			'''
			Ненадолго превращает вас в стаю летучих мышей
			Пока вы находитесь в этой форме, вы получаете неуязвимость, бесконечный полёт и +30% к скорости передвижения
			Стая летучих мышей наносит врагам урон и похищает здоровье
			'''
	}

	ElementsForceEffect: {
		DisplayName: Элементальный сдвиг
		Tooltip: Переключает между режимами магмы и метели
	}
}

