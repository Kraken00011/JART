	AerospecEnchant: {
		DisplayName: Аэрофазовое усиление
		Tooltip:
			'''
			Увеличивает шанс критического удара и урон призывателя 5% за каждый совершенный прыжок
			Бонус пропадает при восстановлении прыжков или использовании ездового питомца
			'''
		CritUp: +{0}% крит.
		CritReset: -{0}% крит.
	}

	MarniteEnchant: {
		DisplayName: Усиление мранитового архитектора
		Tooltip:
			'''
			Увеличивает скорость размещения блоков на 10% и дальность на 5
			Пока вы не атакуете или используете инструменты, вы выпускаете лазеры в ближайших врагов
			[i:CalamityMod/MarniteRepulsionShield] Даёт эффекты от предмета «Мранитовый репульсионный щит»
			'''
	}

	DesertProwlerEnchant: {
		DisplayName: Усиление пустынного мародёра
		Tooltip:
			'''
			Удерживайте ВВЕРХ, чтобы зарядить мощный прыжок, который также увеличивает вашу горизонтальную скорость
			Прыжок можно заряжать только на блоках
			Пока вы удерживайте ВНИЗ, нажмите на клавишу прыжка, чтобы совершить рывок вниз
			И заряжаемый прыжок, и рывок отталкивают врагов
			Приземление сразу после рывка отталкивает врагов и наносит им урон
			'''
	}

	WulfrumEnchant: {
		DisplayName: Вульфрумовое усиление
		Tooltip:
			'''
			Призывает вульфрумового дрона, следующего за вашим курсором
			Дрон сканирует врагов, с которыми сталкивается
			Сканирование врагов показывает их слабости и невосприимчивости к дебаффам
			Зелёный цвет означает слабость, красный - невосприимчивость
			Отсканированные враги также получают дополнительный постепенный урон от дебаффов
			'''
	}

	GaleForce: {
		DisplayName: Сила бури
		Tooltip:
			'''
			Даёт бесконечные дополнительные прыжки
			Отключает крылья, если эффект выше включён
			[i:FargowiltasCrossmod/DesertProwlerEnchant] Удерживайте ВВЕРХ во время прыжка, чтобы запустить себя вверх
			[i:FargowiltasCrossmod/DesertProwlerEnchant] Удерживайте ВНИЗ во время прыжка, чтобы сделать рывок вниз
			[i:FargowiltasCrossmod/SnowRuffianEnchant] Удерживайте ВВЕРХ, чтобы замедлить падение
			[i:FargowiltasCrossmod/VictideEnchant] Удерживайте прыжок, чтобы прикреплять к своей спине острые позвонки
			[i:FargowiltasCrossmod/VictideEnchant] Когда из вас торчит 6 позвонков, следующий прыжок выпустит их
			[i:FargowiltasCrossmod/SulphurEnchant] Позвонки самонаводятся на врагов и накладывают дебафф [cbuff:CalamityMod/SulphuricPoisoning]
			[i:FargowiltasCrossmod/StatigelEnchant] Увеличивает урон в зависимости от вашей скорости, макс. до +40%
			'''
	}

	SnowRuffianEnchant: {
		DisplayName: Усиление снежного бандита
		Tooltip:
			'''
			Позволяет парить в воздухе, даже если на вас нет крыльев
			При медленном падении на крыльях, вы ускоряетесь
			Нажмите ВВЕРХ в медленном падении, чтобы перенаправить движение вверх
			Нажмите ВНИЗ в медленном падении, чтобы сильнее ускоряться
			'''
	}

	DaedalusEnchant: {
		DisplayName: Усиление Дедала
		Tooltip:
			'''
			Увеличивает время полёта на 25%
			При нахождении в воздухе больше одной секунды, ваши атаки начнут призывать мощные стрелы с неба
			Получение урона или контакт с поверхностью убирают этот бонус и срезают половину времени полёта
			'''
	}

