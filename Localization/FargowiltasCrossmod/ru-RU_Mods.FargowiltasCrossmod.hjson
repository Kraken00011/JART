Configs: {
	CalDLCConfig: {
		DisplayName: Конфигурация Calamity

		Headers: {
			Modes: Режимы
			Balance: Балансировка
		}

		ConsumableSummons: {
			Label: Предметы призыва расходуются в режиме Вечность
			Tooltip:
				'''
				Меняет предметы призыва из ваниллы и Calamity, чтобы они расходовались, поверх изменений Calamity.
				Это изменение существует лишь для соответствия с данными особенностями:
				– Предметы призыва возвращаются, если босс ещё не был убит (фактически делая предметы призыва бесконечными)
				– НИП Мутант
				– Варианты предметов призыва из Fargo's Mutant
				'''
		}

		EternityPriorityOverRev: {
			Label: Приоритизировать режим Вечность над режимами Calamity
			Tooltip:
				'''
				Включён: Режим Вечность берёт приоритет над изменениями поведений режима Месть и других сложностей Calamity.
				Выключен: Изменения поведений из сложностей Calamity берут приоритет над режимом Вечность.
				'''
		}

		InfernumDisablesEternity: {
			Label: Режим Инфернум отключает режим Вечность
			Tooltip:
				'''
				Работает только, если включён Infernum Mode.
				Учтите, что Infernum Mode НЕ поддерживается. Проблемы будут появляться независимо от данной конфигурации.
				Включён: Режим Инфернум полностью отключает режим Вечность.
				Выключен: Режим Вечность будет включён, но ИИ боссов режима Инфернум будет брать приоритет, если не включён «Приоритет Вечности над режимами Calamity».
				'''
		}
	}
}

EModeBalance: {
	CrossBalanceGeneric: "Баланс кросс-совместимости: "
	DamageUpGeneric: Урон увеличен на {0}%
	DamageDownGeneric: Урон снижен на {0}%
	PickPowerDownGeneric: Сила добычи снижена на {0}%
	MagicDagger: Урон снижен на 50% до наступления Хардмода
	ProfanedCrystal: Значительно снижен урон, если активен любой миньон или страж
	MythrilEnch: Эффективность снижена для разбойного оружия
	OrichalcumEnch: Эффективность снижена
	Daawnlight: Эффект отключён, пока активно оловянное усиление
	SlimyShield: Не накладывает дебафф [cbuff:FargowiltasSouls/OiledBuff]
	FlightMastery: Скорость полёта снижена во время битвы с боссами не из Fargo's Souls
	EarthForce: Увеличение постепенного урона снижено до 2-кратного
	LifeForce: Скорость и время полёта снижены во время битвы с боссами не из Fargo's Souls
	OnionPackUpgrade: Слот совмещён с [i:FargowiltasSouls/MutantsPact]Договором Мутанта
	PactOnionUpgrade: Слот совмещён с [i:CalamityMod/CelestialOnion]Неземной луковицей и даёт полноценный слот для аксессуара
	Laudanum: Положительные эффекты дебаффов ослаблены вдвое
	TheSponge: Скорость восстановления и время перезарядки увеличены на 25%
	ExoBox: Скорость снижена на 40%
	HardmodeSwords: Увеличение характеристик ослаблено
	OceanCrest: Даёт невосприимчивость к водным дебаффам режима Вечность
	CalEnch: Накапливаемый урон не может быть выше 500000
}

